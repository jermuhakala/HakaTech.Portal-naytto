@*
    ChangePassword.cshtml — Salasanan vaihtolomake.

    Kirjautunut käyttäjä voi vaihtaa oman salasanansa tällä lomakkeella.
    Lomake vaatii:
      1. Nykyisen salasanan (varmistaa että käyttäjä tietää sen)
      2. Uuden salasanan (täytettävä Identity-vaatimukset: pituus, erikoismerkit jne.)
      3. Uuden salasanan vahvistuksen (täsmää uuteen salasanaan)

    Palvelin tarkistaa nykyisen salasanan ChangePasswordAsync-metodilla.
    Jos nykyinen on väärin → lomakevirhe. Jos oikein → salasana vaihdetaan.

    Yhteys: AccountController.ChangePassword (GET + POST).
*@

@* ChangePasswordViewModel sisältää:
     - CurrentPassword (string): nykyinen salasana
     - NewPassword (string): uusi salasana
     - ConfirmNewPassword (string): uuden salasanan vahvistus ([Compare] validointi) *@
@model HakaTech.Portal.Models.ViewModels.ChangePasswordViewModel

@{
    @* Sivun otsikko välilehdellä. *@
    ViewData["Title"] = L["Auth.ChangePassword.Title"].Value;
}

@* Sivutus: yksi sarake, max. leveys 5/12, ylämarginaali. *@
<div class="row justify-content-center">
    <div class="col-md-5">

        @* Keltainen otsikkorivi varoittaa että kyseessä on sensitiivinen toiminto. *@
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-warning text-dark text-center py-3">
                @* bi-key = avain-ikoni. *@
                <h4 class="mb-0"><i class="bi bi-key me-2"></i>@L["Auth.ChangePassword.Title"]</h4>
            </div>
            <div class="card-body p-4">

                @* Lomake lähettää POST-pyynnön AccountController.ChangePassword-metodille. *@
                <form asp-action="ChangePassword" method="post">

                    @* Koko lomakkeen virheyhteenveto (esim. "Nykyinen salasana on väärin"). *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    @* Nykyinen salasana. *@
                    <div class="mb-3">
                        @* asp-for luo automaattisesti type="password" koska kenttä
                           on [DataType(DataType.Password)] -attribuutilla merkitty
                           ViewModelissa. *@
                        <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                        <input asp-for="CurrentPassword" class="form-control"
                               id="change-current" autocomplete="current-password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    @* Uusi salasana. *@
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        @* autocomplete="new-password" = kertoo selaimelle tämä on uusi salasana,
                           ei täytä automaattisesti vanhaa salasanaa. *@
                        <input asp-for="NewPassword" class="form-control"
                               id="change-new" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    @* Uuden salasanan vahvistus. *@
                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label fw-semibold"></label>
                        @* [Compare("NewPassword")] -attribuutti ViewModelissa vertaa
                           tätä kenttää NewPassword-kenttään. Jos eroavat → virhe. *@
                        <input asp-for="ConfirmNewPassword" class="form-control"
                               id="change-confirm" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    @* Vaihda-painike. d-grid = Bootstrap flex-asettelu joka venyttää
                       painikkeen koko leveyteen. *@
                    <div class="d-grid">
                        @* bg-warning = keltainen; text-dark = tumma teksti (luettavaa keltaisella).
                           fw-semibold = puolipaksu fontti. *@
                        <button type="submit" id="change-submit" class="btn btn-warning btn-lg text-dark fw-semibold">
                            @L["Auth.ChangePassword.Submit"]
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@* jQuery Validation -kirjastot asiakaspuolen validointia varten.
   Esim. tarkistaa että ConfirmNewPassword täsmää NewPassword:iin
   jo ennen palvelimelle lähetystä. *@
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
