@model HakaTech.Portal.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = L["Auth.Register.Title"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm mt-4">
            <div class="card-header text-center py-3">
                <img src="~/img/logo.png" alt="HakaTech Logo"
                     style="height: 36px; width: 36px; border-radius: 8px; object-fit: cover;" class="mb-2" />
                <h4 class="mb-0"><i class="bi bi-person-plus me-2"></i>@L["Auth.Register.Heading"]</h4>
            </div>
            <div class="card-body p-4">

                @if (TempData["SuccessMessage"] is string successMsg)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@successMsg
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" placeholder="@L["Auth.Register.FullNamePlaceholder"]"
                               id="register-fullname" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" placeholder="@L["Auth.Login.EmailPlaceholder"]"
                               id="register-email" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" class="form-control" placeholder="@L["Auth.Register.PasswordPlaceholder"]"
                               id="register-password" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="@L["Auth.Register.ConfirmPlaceholder"]"
                               id="register-confirm" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" id="register-role" class="form-select"
                                onchange="toggleCustomerField(this.value)">
                            <option value="Customer">@L["Auth.Register.RoleCustomer"]</option>
                            <option value="Admin">@L["Auth.Register.RoleAdmin"]</option>
                        </select>
                    </div>

                    <div class="mb-4" id="customer-field"
                         style="@(Model.Role == "Admin" ? "display:none" : "")">
                        <label asp-for="CustomerId" class="form-label fw-semibold"></label>
                        <select asp-for="CustomerId" asp-items="Model.CustomerOptions"
                                id="register-customer" class="form-select">
                            <option value="">@L["Auth.Register.SelectCompany"]</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" id="register-submit" class="btn btn-success btn-lg">
                            <i class="bi bi-person-check me-1"></i>@L["Auth.Register.Submit"]
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
    function toggleCustomerField(role) {
        document.getElementById('customer-field').style.display =
            role === 'Admin' ? 'none' : '';
    }
    </script>
}
