@model HakaTech.Portal.Models.ViewModels.BookingMyViewModel
@using HakaTech.Portal.Models.Domain
@{
    ViewData["Title"] = L["Booking.MyBookings"].Value;
    var fi = new System.Globalization.CultureInfo("fi-FI");

    string TypeColor(BookingSlotType t) => t switch {
        BookingSlotType.Maintenance   => "warning",
        BookingSlotType.Consulting    => "primary",
        BookingSlotType.RemoteSupport => "success",
        _                             => "secondary"
    };
    string TypeName(BookingSlotType t) => t switch {
        BookingSlotType.Maintenance   => "Huolto",
        BookingSlotType.Consulting    => "Konsultointi",
        BookingSlotType.RemoteSupport => "Etätuki",
        _                             => t.ToString()
    };
    string StatusColor(BookingStatus s) => s switch {
        BookingStatus.Confirmed => "success",
        BookingStatus.Pending   => "warning",
        BookingStatus.Cancelled => "secondary",
        _                       => "secondary"
    };
    string StatusName(BookingStatus s) => s switch {
        BookingStatus.Confirmed => "Vahvistettu",
        BookingStatus.Pending   => "Odottaa",
        BookingStatus.Cancelled => "Peruutettu",
        _                       => s.ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-bookmark-check me-2 text-primary"></i>Omat varaukset
    </h2>
    <a asp-action="Index" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-calendar3 me-1"></i>Kalenteri
    </a>
</div>

@if (TempData["SuccessMessage"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-1"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-1"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Tulevat varaukset ───────────────────────────────────────────── *@
<h5 class="mb-3">Tulevat varaukset <span class="badge bg-primary ms-1">@Model.Upcoming.Count</span></h5>

@if (!Model.Upcoming.Any())
{
    <div class="card border-0 shadow-sm text-center py-5 text-muted mb-4">
        <div>
            <i class="bi bi-calendar-plus display-4 d-block mb-3 opacity-50"></i>
            <p class="mb-3">Sinulla ei ole tulevia varauksia.</p>
            <a asp-action="Index" class="btn btn-primary btn-sm">
                <i class="bi bi-calendar3 me-1"></i>Selaa kalenteria
            </a>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-2 mb-4">
        @foreach (var b in Model.Upcoming)
        {
            <div class="card border-0 shadow-sm slot-card slot-card-@TypeColor(b.BookingSlot!.SlotType)">
                <div class="card-body py-3">
                    <div class="d-flex gap-3 align-items-center">
                        <div class="text-center flex-shrink-0" style="width:52px">
                            <div class="fw-bold fs-5 lh-1">
                                @b.BookingSlot.StartTime.ToString("HH:mm")
                            </div>
                            <div class="text-muted small">
                                @b.BookingSlot.StartTime.ToString("d.M.", fi)
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex flex-wrap gap-1 mb-1">
                                <span class="badge text-bg-@TypeColor(b.BookingSlot.SlotType)">
                                    @TypeName(b.BookingSlot.SlotType)
                                </span>
                                <span class="badge text-bg-@StatusColor(b.Status)">
                                    @StatusName(b.Status)
                                </span>
                            </div>
                            <div class="fw-semibold">@b.BookingSlot.Title</div>
                            <div class="text-muted small">
                                @b.BookingSlot.StartTime.ToString("dddd d.M.yyyy HH:mm", fi)
                                – @b.BookingSlot.EndTime.ToString("HH:mm")
                                (@b.BookingSlot.DurationMinutes min)
                            </div>
                            @if (!string.IsNullOrWhiteSpace(b.Notes))
                            {
                                <div class="text-muted small mt-1 fst-italic">"@b.Notes"</div>
                            }
                        </div>
                        <div class="flex-shrink-0">
                            @if (b.Status != BookingStatus.Cancelled)
                            {
                                <form asp-action="Cancel" asp-route-id="@b.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            data-confirm="Peruutetaanko varaus '@b.BookingSlot.Title'?">
                                        <i class="bi bi-x-circle me-1"></i>Peruuta
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ── Menneet ja peruutetut ───────────────────────────────────────── *@
@if (Model.Past.Any())
{
    <h5 class="mb-3 text-muted">Menneet ja peruutetut <span class="badge bg-secondary ms-1">@Model.Past.Count</span></h5>
    <div class="d-flex flex-column gap-2">
        @foreach (var b in Model.Past)
        {
            <div class="card border-0 shadow-sm opacity-65">
                <div class="card-body py-2">
                    <div class="d-flex gap-3 align-items-center">
                        <div class="text-center flex-shrink-0 text-muted" style="width:52px">
                            <div class="fw-semibold lh-1">
                                @b.BookingSlot?.StartTime.ToString("HH:mm")
                            </div>
                            <div class="small">
                                @b.BookingSlot?.StartTime.ToString("d.M.", fi)
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex flex-wrap gap-1 mb-1">
                                <span class="badge text-bg-@StatusColor(b.Status)">@StatusName(b.Status)</span>
                            </div>
                            <div class="fw-medium">@b.BookingSlot?.Title</div>
                            @if (!string.IsNullOrWhiteSpace(b.CancellationReason))
                            {
                                <div class="text-muted small">Syy: @b.CancellationReason</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<style>
.slot-card { border-left: 4px solid transparent !important; }
.slot-card-warning  { border-left-color: #f59e0b !important; }
.slot-card-primary  { border-left-color: #3b82f6 !important; }
.slot-card-success  { border-left-color: #22c55e !important; }
.opacity-65 { opacity: .65; }
</style>
}
