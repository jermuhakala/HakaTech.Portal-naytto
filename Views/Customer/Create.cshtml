@model HakaTech.Portal.Models.ViewModels.CustomerFormViewModel
@{
    ViewData["Title"] = "Lisää asiakas";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Asiakkaat</a></li>
        <li class="breadcrumb-item active">Lisää asiakas</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-building-add me-2"></i>Uusi asiakas</h5>
            </div>
            <div class="card-body p-4">

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="CompanyName" class="form-label fw-semibold"></label>
                            <input asp-for="CompanyName" class="form-control" id="create-company"
                                   placeholder="Esimerkki Oy" />
                            <span asp-validation-for="CompanyName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BusinessId" class="form-label fw-semibold"></label>
                            <input asp-for="BusinessId" class="form-control" id="create-businessid"
                                   placeholder="1234567-8" />
                            <span asp-validation-for="BusinessId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-7">
                            <label asp-for="ContactEmail" class="form-label fw-semibold"></label>
                            <input asp-for="ContactEmail" class="form-control" id="create-email"
                                   placeholder="info@yritys.fi" />
                            <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="Phone" class="form-label fw-semibold"></label>
                            <input asp-for="Phone" class="form-control" id="create-phone"
                                   placeholder="+358 40 123 4567" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label fw-semibold"></label>
                            <input asp-for="Address" class="form-control" id="create-address"
                                   placeholder="Esimerkkikatu 1, 00100 Helsinki" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" id="create-active" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" id="create-submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Tallenna
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Peruuta</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
