@*
    Customer/Details.cshtml — Asiakkaan detaljisivu (vain admin).

    Kattava yhteenvetosvu yhdestä asiakasyrityksestä:
      - Yhteystiedot ja perustiedot
      - Sopimukset (kuukausihinnalla + voimassaoloajalla)
      - Käyttäjät (lista + "Lisää käyttäjä" -painike)
      - Viimeisimmät tiketit (linkillä tikettisivulle)
      - Viimeisimmät laskut (tilalla + linkillä laskusivulle)

    Toimintopainikkeet:
      - Muokkaa yritystä
      - Aktivoi/Deaktivoi (ToggleActive)
      - Luo käyttäjätili (Account/Register suoraan tälle yritykselle)
      - Poista yritys (vahvistusvaatimus)

    Yhteys: CustomerController.Details.
*@

@* Model = yksittäinen Customer-entiteetti, jossa navigation propertyina
   Users, Contracts, Tickets ja Invoices (ladattu kontrollerissa Include:lla). *@
@model HakaTech.Portal.Models.Domain.Customer
@using HakaTech.Portal.Models.Domain

@{
    @* Sivun otsikko = yrityksen nimi. *@
    ViewData["Title"] = Model.CompanyName;

    @* Leivänmuru: "Asiakkaat > YritysNimi". *@
    ViewData["Breadcrumbs"] = new List<(string, string?)>
    {
        (L["Customer.Index.Title"].Value, Url.Action("Index", "Customer")),
        (Model.CompanyName, null)
    };

    @* Apufunktiot: lokalisoidut tilatekstit laskuille ja tiketeille. *@
    string StatusLabel(InvoiceStatus s)    => L[$"InvoiceStatus.{s}"].Value;
    string TStatusLabel(TicketStatus s)    => L[$"TicketStatus.{s}"].Value;
    string TPriorityLabel(TicketPriority p) => L[$"TicketPriority.{p}"].Value;
}

@* Bootstrap-leivänmurut sivun yläosassa (toistuu sivupalkin leivänmurujen lisäksi). *@
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@L["Customer.Index.Title"]</a></li>
        <li class="breadcrumb-item active">@Model.CompanyName</li>
    </ol>
</nav>

@* Otsikkorivi + toimintopainikkeet. *@
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        @* Yritysnimi + passiivinen-merkki jos yritys ei ole aktiivinen. *@
        <h2 class="mb-0">
            <i class="bi bi-building me-2"></i>@Model.CompanyName
            @if (!Model.IsActive)
            {
                @* Passiiviselle yritykselle harmaannettu "Passiivinen"-merkki. *@
                <span class="badge bg-secondary fs-6 ms-2">@L["Common.Inactive"]</span>
            }
        </h2>
        @* Y-tunnus pienempänä otsikon alla. *@
        <small class="text-muted">@L["Customer.Col.BusinessId"]: @Model.BusinessId</small>
    </div>

    @* Toimintopainikkeet vain admineille. *@
    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex gap-2 flex-wrap">
            @* Muokkaa-linkki. *@
            <a asp-action="Edit" asp-route-id="@Model.Id"
               id="btn-customer-edit" class="btn btn-outline-secondary">
                <i class="bi bi-pencil me-1"></i>@L["Common.Edit"]
            </a>

            @* Aktivoi/Deaktivoi-painike. ToggleActive vaihtaa IsActive-lipun.
               Painikkeen väri ja teksti muuttuu tilan mukaan:
               - Aktiivinen → "Deaktivoi" (keltainen varoitus)
               - Passiivinen → "Aktivoi" (vihreä) *@
            <form asp-action="ToggleActive" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="btn @(Model.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                    <i class="bi @(Model.IsActive ? "bi-pause-circle" : "bi-play-circle") me-1"></i>
                    @(Model.IsActive ? L["Customer.Details.Deactivate"].Value : L["Customer.Details.Activate"].Value)
                </button>
            </form>

            @* Luo käyttäjätili tälle yritykselle. asp-route-customerId välittää
               yrityksen ID Register-sivulle, joka esitäyttää yrityksen valitulle asiakkaalle. *@
            <a asp-controller="Account" asp-action="Register" asp-route-customerId="@Model.Id"
               class="btn btn-outline-primary">
                <i class="bi bi-person-plus me-1"></i>@L["Customer.Details.CreateAccount"]
            </a>

            @* Poista-lomake. Vahvistusikkuna ennen poistoa.
               JsonSerializer.Serialize = muuntaa lokalisoidun vahvistustekstin
               JS-merkkijonoksi (käsittelee lainausmerkit oikein).
               string.Format = lisää yrityksen nimen viestiin. *@
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(string.Format(L["Customer.Details.DeleteConfirm"].Value, Model.CompanyName))));">
                @Html.AntiForgeryToken()
                <button type="submit" id="btn-customer-delete" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>@L["Common.Delete"]
                </button>
            </form>
        </div>
    }
</div>

@* Yhteystiedot + Sopimukset vierekkäin (50%/50%). *@
<div class="row g-3 mb-4">

    @* Yhteystiedot-kortti. *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>@L["Customer.Details.Contacts"]</div>
            <div class="card-body">
                @* <dl> = definition list; <dt> = termi, <dd> = arvo.
                   row-asettelu Bootstrap-gridillä: termi 5/12, arvo 7/12. *@
                <dl class="row mb-0">
                    <dt class="col-sm-5">@L["Customer.Col.Email"]</dt>
                    <dd class="col-sm-7">
                        @* mailto-linkki: klikkaamalla avautuu sähköpostiohjelma. *@
                        <a href="mailto:@Model.ContactEmail">@Model.ContactEmail</a>
                    </dd>
                    <dt class="col-sm-5">@L["Customer.Col.Phone"]</dt>
                    <dd class="col-sm-7">@(Model.Phone ?? "—")</dd>
                    <dt class="col-sm-5">@L["Customer.Details.Address"]</dt>
                    <dd class="col-sm-7">@(Model.Address ?? "—")</dd>
                    <dt class="col-sm-5">@L["Dash.Col.Created"]</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("dd.MM.yyyy")</dd>
                </dl>
            </div>
        </div>
    </div>

    @* Sopimukset-kortti. *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-file-text me-2"></i>@L["Customer.Details.Contracts"]</div>
            <div class="card-body">
                @if (!Model.Contracts.Any())
                {
                    <span class="text-muted">@L["Customer.Details.NoContracts"]</span>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var con in Model.Contracts)
                        {
                            <li class="list-group-item px-0">
                                @* Sopimuksen tyyppi (esim. "Tuki", "Konsultointi"). *@
                                <span class="fw-semibold">@con.Type</span>
                                @* Voimassaolo-merkki. *@
                                <span class="badge @(con.IsActive ? "bg-success" : "bg-secondary") ms-2">
                                    @(con.IsActive ? L["Common.Active"].Value : L["Customer.Details.ContractEnded"].Value)
                                </span>
                                <br />
                                @* Voimassaoloaika ja kuukausihinta.
                                   ToString("C") = valuuttamuoto (esim. "150,00 €") — riippuu kulttuurista. *@
                                <small class="text-muted">
                                    @con.StartDate.ToString("dd.MM.yyyy") – @con.EndDate.ToString("dd.MM.yyyy") |
                                    @con.MonthlyPrice.ToString("C")
                                </small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@* Käyttäjät-kortti (vain adminille). *@
@if (User.IsInRole("Admin"))
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-people me-2"></i>@L["Customer.Details.Users"]
                @* Lukumäärä-merkki käyttäjien vieressä. *@
                <span class="badge bg-secondary ms-1">@Model.Users.Count</span>
            </span>
            @* Lisää käyttäjä -painike vie Register-sivulle esitäytetyllä yrityksellä. *@
            <a asp-controller="Account" asp-action="Register" asp-route-customerId="@Model.Id"
               class="btn btn-sm btn-outline-primary">
                <i class="bi bi-person-plus me-1"></i>@L["Customer.Details.AddUser"]
            </a>
        </div>
        <div class="card-body p-0">
            @if (!Model.Users.Any())
            {
                <p class="text-muted p-3 mb-0">@L["Customer.Details.NoUsers"]</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@L["Customer.Details.Col.Name"]</th>
                                <th>@L["Customer.Col.Email"]</th>
                                @* d-none d-md-table-cell = piilossa mobiililla (tila rajallinen). *@
                                <th class="d-none d-md-table-cell">@L["Customer.Details.Col.UserName"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Käyttäjät aakkosjärjestyksessä nimen mukaan. *@
                            @foreach (var u in Model.Users.OrderBy(u => u.FullName))
                            {
                                <tr>
                                    @* Jos FullName on tyhjä merkkijono, näytetään em-viiva. *@
                                    <td>@(u.FullName.Length > 0 ? u.FullName : "—")</td>
                                    <td><a href="mailto:@u.Email">@u.Email</a></td>
                                    <td class="d-none d-md-table-cell text-muted small">@u.UserName</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* Tiketit + Laskut vierekkäin. *@
<div class="row g-3">

    @* Tiketit-kortti. *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-ticket me-2"></i>@L["Customer.Details.RecentTickets"]</span>
                @* "Kaikki tiketit" -linkki suodattaa customerId:n mukaan. *@
                <a asp-controller="Ticket" asp-action="Index" asp-route-customerId="@Model.Id"
                   class="btn btn-sm btn-outline-primary">@L["Common.All"]</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Tickets.Any())
                {
                    <p class="text-muted p-3 mb-0">@L["Customer.Details.NoTickets"]</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var t in Model.Tickets)
                        {
                            <li class="list-group-item">
                                @* Tiketti-linkki. *@
                                <a asp-controller="Ticket" asp-action="Details" asp-route-id="@t.Id"
                                   class="text-decoration-none fw-semibold">
                                    #@t.Id @t.Title
                                </a>
                                <br />
                                @* Tila | Prioriteetti | Päivämäärä pienempänä. *@
                                <small class="text-muted">
                                    @TStatusLabel(t.Status) | @TPriorityLabel(t.Priority) | @t.CreatedAt.ToString("dd.MM.yyyy")
                                </small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    @* Laskut-kortti. *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-receipt me-2"></i>@L["Customer.Details.RecentInvoices"]</span>
                @* Kaikki laskut suodatettuna tälle asiakkaalle. *@
                <a asp-controller="Invoice" asp-action="Index" asp-route-customerId="@Model.Id"
                   class="btn btn-sm btn-outline-primary">@L["Common.All"]</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Invoices.Any())
                {
                    <p class="text-muted p-3 mb-0">@L["Customer.Details.NoInvoices"]</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var inv in Model.Invoices)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    @* Laskun numero linkkinä. *@
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@inv.Id"
                                       class="text-decoration-none fw-semibold">
                                        @inv.InvoiceNumber
                                    </a>
                                    <br />
                                    <small class="text-muted">@inv.InvoiceDate.ToString("dd.MM.yyyy") | @StatusLabel(inv.Status)</small>
                                </div>

                                @* Laskun tila-merkki:
                                   Maksettu → vihreä, Erääntynyt → punainen, Muut → keltainen. *@
                                <span class="badge @(inv.Status == InvoiceStatus.Paid
                                    ? "bg-success"
                                    : inv.Status == InvoiceStatus.Overdue
                                        ? "bg-danger"
                                        : "bg-warning text-dark")">
                                    @StatusLabel(inv.Status)
                                </span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
