@model IEnumerable<HakaTech.Portal.Models.Domain.Customer>
@{
    ViewData["Title"] = "Asiakkaat";
    var search = ViewBag.Search as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-building me-2"></i>Asiakkaat</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" id="btn-customer-create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Lisää asiakas
        </a>
    }
</div>

@if (TempData["SuccessMessage"] is string sMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>@sMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] is string eMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>@eMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width:480px;">
        <input type="text" name="search" value="@search"
               class="form-control" id="customer-search"
               placeholder="Hae nimellä, Y-tunnuksella tai sähköpostilla…" />
        <button type="submit" class="btn btn-outline-secondary">
            <i class="bi bi-search"></i>
        </button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn btn-outline-danger" title="Tyhjennä haku">
                <i class="bi bi-x-lg"></i>
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i>
        @(string.IsNullOrEmpty(search)
            ? "Asiakkaita ei löydy. Lisää ensimmäinen asiakas yllä olevalla painikkeella."
            : $"Haulla \"{search}\" ei löytynyt asiakkaita.")
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Yritysnimi</th>
                    <th>Y-tunnus</th>
                    <th>Sähköposti</th>
                    <th>Puhelin</th>
                    <th class="text-center">Tila</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@c.Id"
                               class="fw-semibold text-decoration-none">
                                @c.CompanyName
                            </a>
                        </td>
                        <td class="text-muted small">@c.BusinessId</td>
                        <td class="text-muted small">@c.ContactEmail</td>
                        <td class="text-muted small">@(c.Phone ?? "—")</td>
                        <td class="text-center">
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">Aktiivinen</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Epäaktiivinen</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@c.Id"
                               class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small">Yhteensä @Model.Count() asiakasta.</p>
}
