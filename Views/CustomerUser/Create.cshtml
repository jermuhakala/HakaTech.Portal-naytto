@model HakaTech.Portal.Models.ViewModels.CustomerUserFormViewModel
@{
    var customer = ViewBag.Customer as HakaTech.Portal.Models.Domain.Customer;
    ViewData["Title"] = "Lisää käyttäjä";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" asp-route-customerId="@Model.CustomerId"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h2 class="mb-0">Lisää käyttäjä</h2>
        <small class="text-muted">@customer?.CompanyName</small>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CustomerId" />

                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-medium"></label>
                        <input asp-for="FullName" class="form-control" placeholder="Etunimi Sukunimi" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium"></label>
                        <input asp-for="Email" class="form-control" placeholder="kayttaja@esimerkki.fi" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-medium"></label>
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <div class="form-text">Vähintään 8 merkkiä, iso kirjain ja numero.</div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 p-3 bg-light rounded">
                        <div class="form-check">
                            <input asp-for="IsCustomerAdmin" class="form-check-input" />
                            <label asp-for="IsCustomerAdmin" class="form-check-label fw-medium">
                                Yrityksen pääkäyttäjä
                            </label>
                        </div>
                        <div class="form-text mt-1">
                            Pääkäyttäjä voi hallita oman yrityksensä käyttäjiä.
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-person-plus me-1"></i>Luo käyttäjä
                        </button>
                        <a asp-action="Index" asp-route-customerId="@Model.CustomerId"
                           class="btn btn-outline-secondary">Peruuta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
