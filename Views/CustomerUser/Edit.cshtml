@*
    CustomerUser/Edit.cshtml — Asiakaskäyttäjän muokkauslomake.

    Muokattavissa:
      - Koko nimi
      - Sähköpostiosoite (myös kirjautumistunnus)
      - Pääkäyttäjä-lippu (IsCustomerAdmin)

    Salasanaa ei vaihdeta täällä — käyttäjä voi vaihtaa sen itse
    ChangePassword-sivulla.

    Turvallisuus:
      - UserId piilokenttänä — kontrolleri tarkistaa ettei voi muokata toista käyttäjää.
      - CustomerId piilokenttänä — ohjausparametri paluusiirtymään.
      - CustomerAdmin ei voi muokata omaa tiliään (kontrolleri palauttaa Forbid()).

    Yhteys: CustomerUserController.Edit (GET = esitäytetty lomake, POST = tallennetaan).
*@

@* CustomerUserEditViewModel sisältää:
   UserId (string GUID), FullName, Email, IsCustomerAdmin (bool), CustomerId (int) *@
@model HakaTech.Portal.Models.ViewModels.CustomerUserEditViewModel

@{
    @* isAdmin-lippu — admin näkee enemmän (vaikka tässä lomakkeessa ei vaikuta). *@
    bool isAdmin = ViewBag.IsAdmin == true;
    ViewData["Title"] = L["CustomerUser.Edit"].Value;
}

@* Otsikkorivi. *@
<div class="d-flex align-items-center gap-3 mb-4">
    @* Takaisin käyttäjälistaan — tarvitsee customerId:n URL-parametriksi. *@
    <a asp-action="Index" asp-route-customerId="@Model.CustomerId"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0">Muokkaa käyttäjää</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    @* UserId piilokenttänä — kontrolleri käyttää tätä FindByIdAsync:ssa.
                       Käyttäjä-ID on GUID-merkkijono (ASP.NET Identity). *@
                    <input type="hidden" asp-for="UserId" />

                    @* CustomerId tarvitaan paluuohjauksessa.
                       RedirectToAction(nameof(Index), new { customerId = target.CustomerId }) *@
                    <input type="hidden" asp-for="CustomerId" />

                    @* Virheyhteenveto. *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    @* Koko nimi — esitäytetty kontrollerin hakemasta käyttäjästä. *@
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-medium"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    @* Sähköposti — jos muutetaan, kontrolleri päivittää myös UserName:n
                       (OrdinalIgnoreCase-vertailu muutoksen tunnistamiseen). *@
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-medium"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    @* Pääkäyttäjä-asetus. *@
                    <div class="mb-4 p-3 bg-light rounded">
                        <div class="form-check">
                            @* Esitäytetty: jos käyttäjä on jo pääkäyttäjä, rasti on päällä. *@
                            <input asp-for="IsCustomerAdmin" class="form-check-input" />
                            <label asp-for="IsCustomerAdmin" class="form-check-label fw-medium">
                                Yrityksen pääkäyttäjä
                            </label>
                        </div>
                        <div class="form-text mt-1">
                            Pääkäyttäjä voi hallita oman yrityksensä käyttäjiä.
                        </div>
                    </div>

                    @* Toimintopainikkeet. *@
                    <div class="d-flex gap-2">
                        @* bi-floppy = levyke-ikoni (tallenna). *@
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>Tallenna
                        </button>
                        <a asp-action="Index" asp-route-customerId="@Model.CustomerId"
                           class="btn btn-outline-secondary">Peruuta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
