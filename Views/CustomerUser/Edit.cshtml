@*
    CustomerUser/Edit.cshtml — Asiakaskäyttäjän muokkauslomake
    (nimi, sähköposti, customer-admin -lippu). Salasanaa ei vaihdeta täällä.
*@
@model HakaTech.Portal.Models.ViewModels.CustomerUserEditViewModel
@{
    bool isAdmin = ViewBag.IsAdmin == true;
    ViewData["Title"] = L["CustomerUser.Edit"].Value;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" asp-route-customerId="@Model.CustomerId"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0">Muokkaa käyttäjää</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="CustomerId" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-medium"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-medium"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 p-3 bg-light rounded">
                        <div class="form-check">
                            <input asp-for="IsCustomerAdmin" class="form-check-input" />
                            <label asp-for="IsCustomerAdmin" class="form-check-label fw-medium">
                                Yrityksen pääkäyttäjä
                            </label>
                        </div>
                        <div class="form-text mt-1">
                            Pääkäyttäjä voi hallita oman yrityksensä käyttäjiä.
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>Tallenna
                        </button>
                        <a asp-action="Index" asp-route-customerId="@Model.CustomerId"
                           class="btn btn-outline-secondary">Peruuta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
