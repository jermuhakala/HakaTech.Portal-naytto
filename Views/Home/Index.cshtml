@*
    Home/Index.cshtml — Portaalin etusivu (Dashboard).

    Rakenne:
      1. Tiedotteet (Announcement-alertit, ei draggable)
      2. Admin: odottavat tarjouspyynnöt -alert
      3. Asiakas: uudet lähetetyt laskut -alert
      4. Hero-palkki: tervehdys + widgetien layoutin hallinta
      5. Widget-ruudukko (SortableJS drag-and-drop):
           "kpi"          → KPI-kortit (tikettejä, laskuja, asiakkaita jne.)
           "tickets"      → Tikettijakauma (donut) + avoimet tiketit taulukossa
           "invoices"     → Erääntyvät ja erääntyneet laskut
           "calendar"     → Tulevat varausajankohdat
           "quickactions" → Pikalinkkipainikkeet

    Widgettien järjestys (WidgetOrder) tallennetaan palvelimelle
    POST /Home/SaveLayout -kutsulla (SortableJS onEnd-callback).

    JavaScript-toiminnot:
      - SortableJS: drag-and-drop widgetijärjestyksen muuttaminen
      - Chart.js (donut): tikettien tilajakauma
      - Chart.js (sparkline): trendiviivakaaviot KPI-korteissa
      - Layout preset: kolme valmiiksi määriteltyä näkymätilaa
        (default/compact/focus), tallennetaan localStorage:en

    Yhteys: HomeController.Index (GET) ja SaveLayout (POST).
*@

@* Malli = DashboardViewModel. Sisältää kaiken dashboardille tarvittavan datan:
   tiketit, laskut, varaukset, asiakkaat, tiedotteet, WidgetOrder jne. *@
@model HakaTech.Portal.Models.ViewModels.DashboardViewModel
@using HakaTech.Portal.Models.Domain

@{
    ViewData["Title"] = L["Nav.Overview"].Value;

    @* uiCulture = käyttöliittymän kulttuuriasetus (esim. "fi-FI").
       Tarvitaan päivämäärä- ja kuukausimuotoiluihin (ToString("dddd", uiCulture)). *@
    var uiCulture = System.Globalization.CultureInfo.CurrentUICulture;
}

@* dashboard-wrapper = mukautettu CSS-container koko dashboardille.
   id="dashboardRoot" = JavaScript viittaa tähän (edit-mode-luokan lisäämiseen). *@
<div class="dashboard-wrapper" id="dashboardRoot">

    @* ── 1. Tiedotteet (kiinteä yläosa) ──────────────────────────── *@
    @* Tiedotteet eivät ole draggable-widgetejä — ne ovat aina päällimmäisenä.
       ActiveAnnouncements = vain voimassaolevat tiedotteet (kontrolleri suodattaa). *@
    @if (Model.ActiveAnnouncements.Any())
    {
        <div class="mb-3">
            @foreach (var ann in Model.ActiveAnnouncements)
            {
                @* Alertin CSS-luokka ja ikoni riippuvat tiedotteen tyypistä:
                   Maintenance → keltainen (warning) + työkaluikoni
                   Warning     → punainen (danger) + huutomerkki
                   Muu (Info)  → sininen (info) + info-ympyrä *@
                var alertClass = ann.Type switch
                {
                    AnnouncementType.Maintenance => "alert-warning",
                    AnnouncementType.Warning     => "alert-danger",
                    _                            => "alert-info"
                };
                var icon = ann.Type switch
                {
                    AnnouncementType.Maintenance => "bi-tools",
                    AnnouncementType.Warning     => "bi-exclamation-triangle-fill",
                    _                            => "bi-info-circle-fill"
                };

                @* alert-dismissible = käyttäjä voi sulkea alertin X-painikkeella.
                   fade show = Bootstrap 5:n animoitu katoaminen suljetessa. *@
                <div class="alert @alertClass alert-dismissible fade show mb-2" role="alert">
                    <div class="d-flex align-items-start gap-2">
                        @* mt-1 flex-shrink-0 = ikoni pysyy vasemmassa yläkulmassa
                           eikä kutiste kun teksti on pitkä. *@
                        <i class="bi @icon mt-1 flex-shrink-0"></i>
                        <div>
                            @* Tiedotteen otsikko lihavoituna. *@
                            <strong>@ann.Title</strong>
                            @* Lisäteksti — näytetään vain jos asetettu. *@
                            @if (!string.IsNullOrWhiteSpace(ann.Content))
                            {
                                <span class="ms-1">— @ann.Content</span>
                            }
                            @* Voimassaoloaika — näytetään jos asetettu.
                               string.Format = muotoilee lokalisoidun merkkijonon (esim. "Voimassa {0} asti").
                               ToLocalTime() = UTC → paikallinen aika. *@
                            @if (ann.ValidUntil.HasValue)
                            {
                                <span class="text-muted small ms-2">(@string.Format(L["Common.ValidUntil"].Value, ann.ValidUntil.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")))</span>
                            }
                        </div>
                    </div>
                    @* Sulkemispainike (X). data-bs-dismiss="alert" = Bootstrap sulkee alertin. *@
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>
    }

    @* ── 2. Admin: odottavat tarjouspyynnöt ─────────────────────── *@
    @* Näytetään vain adminille jos tarjouspyyntöjä on odottamassa. *@
    @if (Model.IsAdmin && Model.PendingQuoteRequests > 0)
    {
        @* d-flex align-items-center gap-3 = ikoni + teksti + painike vierekkäin. *@
        <div class="alert alert-warning alert-dismissible fade show mb-3 d-flex align-items-center gap-3" role="alert">
            @* fs-4 = isompi fonttikoko ikonille. flex-shrink-0 = ei tiivisty. *@
            <i class="bi bi-envelope-exclamation-fill fs-4 flex-shrink-0"></i>
            <div class="flex-grow-1">
                @* string.Format = korvaa {0}:n odottavien pyyntöjen lukumäärällä. *@
                <strong>@string.Format(L["Dash.Alert.QuoteRequests"].Value, Model.PendingQuoteRequests)</strong>
                @L["Dash.Alert.QuoteRequestsSub"]
            </div>
            @* Suora linkki tarjouspyyntölistaan. text-nowrap = teksti ei rivitä. *@
            <a asp-controller="ServiceCatalog" asp-action="Requests" class="btn btn-warning btn-sm text-nowrap">
                <i class="bi bi-arrow-right me-1"></i>@L["Dash.Alert.ViewRequests"]
            </a>
            <button type="button" class="btn-close ms-2" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── 3. Asiakas: uudet lähetetyt laskut ─────────────────────── *@
    @* Näytetään vain asiakkaalle (ei adminille) jos uusia laskuja on. *@
    @if (!Model.IsAdmin && Model.NewSentInvoices.Any())
    {
        <div class="alert alert-info alert-dismissible fade show mb-3" role="alert">
            <div class="d-flex align-items-start gap-3">
                <i class="bi bi-receipt fs-4 flex-shrink-0 mt-1"></i>
                <div class="flex-grow-1">
                    @* Laskujen lukumäärä otsikossa. *@
                    <strong>@string.Format(L["Dash.Alert.NewInvoices"].Value, Model.NewSentInvoices.Count)</strong>
                    @* Lista uusista laskuista: numero + summa + eräpäivä. *@
                    <ul class="mb-0 mt-1 ps-3">
                        @foreach (var inv in Model.NewSentInvoices)
                        {
                            <li>
                                @* Laskun numero linkkinä Details-sivulle. *@
                                <a asp-controller="Invoice" asp-action="Details" asp-route-id="@inv.Id" class="alert-link fw-semibold">@inv.InvoiceNumber</a>
                                @* "N2" = kaksi desimaalia (esim. "1 500,00 €"). *@
                                — @inv.TotalAmount.ToString("N2") €,
                                @* Eräpäivä suomalainen muoto. *@
                                @L["Dash.Alert.DueDate"] <strong>@inv.DueDate.ToString("dd.MM.yyyy")</strong>
                            </li>
                        }
                    </ul>
                </div>
                @* Linkki laskujen indeksisivulle. align-self-start = pysyy yläreunassa. *@
                <a asp-controller="Invoice" asp-action="Index" class="btn btn-outline-info btn-sm text-nowrap align-self-start">
                    <i class="bi bi-arrow-right me-1"></i>@L["Nav.Invoices"]
                </a>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── 4. Hero-palkki: tervehdys + layoutin hallinta ───────────── *@
    @{
        @* Tervehdyksen lokalisointiavain valitaan kellonajan mukaan:
           < 11 = "Hyvää huomenta", < 18 = "Hyvää päivää", muuten = "Hyvää iltaa". *@
        var hour = DateTime.Now.Hour;
        var greetingKey = hour < 11 ? "UI.Dash.Hero.Greeting.Morning"
                        : hour < 18 ? "UI.Dash.Hero.Greeting.Afternoon"
                        : "UI.Dash.Hero.Greeting.Evening";
    }

    @* dash-hero = mukautettu CSS-komponentti hero-palkille. *@
    <section class="dash-hero mb-4">
        <div class="dash-hero-inner">
            <div>
                @* Päivämäärä pitkässä muodossa (esim. "tiistai 12. toukokuuta 2026").
                   "dddd d. MMMM yyyy" = formaatti: pitkä viikonpäivä, päivä, pitkä kuukausi, vuosi.
                   uiCulture = varmistaa suomenkielisen muotoilun. *@
                <p class="dash-hero-eyebrow">@DateTime.Now.ToString("dddd d. MMMM yyyy", uiCulture)</p>
                @* Tervehdys + käyttäjänimi (WelcomeName = FullName tai Email). *@
                <h1 class="dash-hero-title">@L[greetingKey], @Model.WelcomeName</h1>
                <p class="dash-hero-sub">@L["Dash.Welcome.Sub"]</p>
            </div>

            @* Oikealla: roolibadge + layout-preset-valitsin + muokkausnappi. *@
            <div class="dash-hero-actions">
                @* Roolibadge: eri tyyli adminille ja asiakkaalle. *@
                @if (Model.IsAdmin)
                {
                    <span class="badge-role"><i class="bi bi-shield-check"></i> @L["Role.Admin"]</span>
                }
                else
                {
                    <span class="badge-role badge-customer"><i class="bi bi-person"></i> @L["Role.Customer"]</span>
                }

                @* Layout-preset-valitsin: kolme radio-nappia.
                   role="radiogroup" = saavutettavuus: ruudunlukijat ymmärtävät ryhmän.
                   Valinta tallentuu localStorage:en (JavaScript käsittelee).
                   CSS-luokat preset-default/compact/focus vaikuttavat dashboard-layoutiin. *@
                <div class="segmented dash-preset" role="radiogroup" aria-label="Layout preset">
                    @* type="radio" name="dashPreset" = radiopainikeryhmä (vain yksi voi olla valittuna).
                       checked = oletusvalinta "default". *@
                    <input type="radio" name="dashPreset" id="presetDefault" value="default" checked />
                    <label for="presetDefault">@L["UI.Dash.Preset.Default"]</label>

                    <input type="radio" name="dashPreset" id="presetCompact" value="compact" />
                    <label for="presetCompact">@L["UI.Dash.Preset.Compact"]</label>

                    <input type="radio" name="dashPreset" id="presetFocus" value="focus" />
                    <label for="presetFocus">@L["UI.Dash.Preset.Focus"]</label>
                </div>

                @* Muokkaa layoutia -painike. onclick="toggleEditMode()" = JavaScript-funktio.
                   Muokkausmodessa widgetien drag-and-drop aktivoituu. *@
                <button id="editLayoutBtn" type="button" class="btn-lnr variant-ghost size-sm"
                        title="@L["Dash.EditLayout"]" onclick="toggleEditMode()">
                    <i class="bi bi-grid-3x3-gap"></i>
                </button>
            </div>
        </div>
    </section>

    @* ── 5. Widget-ruudukko ───────────────────────────────────────── *@
    @* id="widgetContainer" = SortableJS viittaa tähän drag-and-drop:ia varten.
       WidgetOrder = lista widgetiavaimia järjestyksessä (esim. ["kpi","tickets","invoices"...]).
       Kontrolleri hakee tämän järjestyksen käyttäjäasetuksista tai käyttää oletusta. *@
    <div id="widgetContainer">

        @* Iteroidaan widgettien järjestys ja renderöidään jokainen case-haaran mukaan. *@
        @foreach (var widgetKey in Model.WidgetOrder)
        {
            @* switch ilman switch-expression-nuolta — perinteinen switch(value) Razor-koodissa. *@
            switch (widgetKey)
            {
                case "kpi":
                    @* ── Widget: KPI-kortit ──────────────────────────── *@
                    @* data-widget="kpi" = SortableJS tallentaa tämän arvon layoutjärjestykseen.
                       widget-drag-handle = kahva josta raahaaminen alkaa. *@
                    <div class="widget mb-4" data-widget="kpi">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="widget-drag-handle"><i class="bi bi-grip-vertical"></i></span>
                        </div>

                        @* kpi-grid-lnr = mukautettu CSS-ruudukko KPI-korteille. *@
                        <div class="kpi-grid-lnr">
                            @* Asiakkaiden KPI (vain admin). *@
                            @if (Model.IsAdmin)
                            {
                                @* Component.InvokeAsync("KpiCard", ...) = kutsuu KpiCardViewComponent-komponenttia.
                                   KpiCardVm = ViewModel joka välitetään komponentille:
                                   Label = otsikko, Value = arvo, Sub = alaotsikko,
                                   Icon = Bootstrap-ikonin luokka, Href = klikattava linkki,
                                   Tone = värikaava (info/warning/danger/success/neutral). *@
                                @await Component.InvokeAsync("KpiCard", new { model = new HakaTech.Portal.ViewComponents.KpiCardViewComponent.KpiCardVm {
                                    Label = L["Dash.Kpi.TotalCustomers"].Value,
                                    Value = Model.TotalCustomers.ToString(),
                                    Sub   = string.Format(L["Dash.Kpi.ActiveCustomers"].Value, Model.ActiveCustomers),
                                    Icon  = "bi-building",
                                    Href  = Url.Action("Index", "Customer"),
                                    Tone  = "info"
                                }})
                            }

                            @* Avoimet tiketit — kaikille käyttäjille.
                               Trend = sparkline-trendikäyrän data (7 päivän historia). *@
                            @await Component.InvokeAsync("KpiCard", new { model = new HakaTech.Portal.ViewComponents.KpiCardViewComponent.KpiCardVm {
                                Label = L["Dash.Kpi.OpenTickets"].Value,
                                Value = Model.OpenTickets.ToString(),
                                Sub   = string.Format(L["Dash.Kpi.InProgress"].Value, Model.InProgressTickets),
                                Icon  = "bi-ticket-detailed",
                                Href  = Url.Action("Index", "Ticket", new { status = "Open" }),
                                Tone  = "warning",
                                Trend = Model.TicketsCreatedSpark  @* sparkline-data *@
                            }})

                            @* Kriittiset tiketit — vain admin. *@
                            @if (Model.IsAdmin)
                            {
                                @await Component.InvokeAsync("KpiCard", new { model = new HakaTech.Portal.ViewComponents.KpiCardViewComponent.KpiCardVm {
                                    Label = L["Dash.Kpi.CriticalTickets"].Value,
                                    Value = Model.CriticalTickets.ToString(),
                                    Sub   = string.Format(L["Dash.Kpi.HighPriority"].Value, Model.HighTickets),
                                    Icon  = "bi-exclamation-triangle",
                                    Href  = Url.Action("Index", "Ticket", new { priority = "Critical" }),
                                    Tone  = "danger"
                                }})
                            }

                            @* Erääntyneet laskut — kaikille käyttäjille.
                               Tone ternaari: jos OverdueCount > 0 → punainen, muuten neutraali. *@
                            @await Component.InvokeAsync("KpiCard", new { model = new HakaTech.Portal.ViewComponents.KpiCardViewComponent.KpiCardVm {
                                Label = L["Dash.Kpi.OverdueInvoices"].Value,
                                Value = Model.OverdueCount.ToString(),
                                Sub   = string.Format(L["Dash.Kpi.TotalInvoices"].Value, Model.TotalInvoices),
                                Icon  = "bi-receipt",
                                Href  = Url.Action("Index", "Invoice", new { status = "Overdue" }),
                                Tone  = Model.OverdueCount > 0 ? "danger" : "neutral",
                                Trend = Model.InvoicesIssuedSpark
                            }})

                            @* Maksamaton summa — kaikille käyttäjille.
                               "N0" = kokonaisluku tuhaterotuksella (esim. "12 500 €"). *@
                            @await Component.InvokeAsync("KpiCard", new { model = new HakaTech.Portal.ViewComponents.KpiCardViewComponent.KpiCardVm {
                                Label = L["Dash.Kpi.Unpaid"].Value,
                                Value = Model.UnpaidTotal.ToString("N0") + " €",
                                Sub   = L["Dash.Kpi.UnpaidSub"].Value,
                                Icon  = "bi-currency-euro",
                                Href  = Url.Action("Index", "Invoice"),
                                Tone  = "success",
                                Trend = Model.UnpaidTotalSpark
                            }})
                        </div>
                    </div>
                    break;

                case "tickets":
                    @* ── Widget: Tiketit ────────────────────────────── *@
                    <div class="widget mb-4" data-widget="tickets">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="widget-drag-handle"><i class="bi bi-grip-vertical"></i></span>
                        </div>

                        @* dashboard-main-grid = mukautettu CSS-ruudukko taulukolle + kaaviolle. *@
                        <div class="dashboard-main-grid">
                            <div class="dashboard-col-left">

                                @* Tikettien tilajakauma donut-kaaviona — vain adminille.
                                   canvas-elementti jolla Chart.js piirtää kaavion. *@
                                @if (Model.IsAdmin && Model.TicketsByStatus.Any())
                                {
                                    <div class="dash-card mb-4">
                                        <div class="dash-card-header">
                                            <i class="bi bi-pie-chart-fill"></i> @L["Dash.Tickets.StatusDistribution"]
                                        </div>
                                        @* chart-container = paikka Chart.js -kaaviolle.
                                           position:relative + height:190px = Chart.js vaatii
                                           eksplisiittisen korkeuden responsive-moodissa. *@
                                        <div class="dash-card-body chart-container" style="position:relative; height:190px; padding: .75rem 1rem;">
                                            @* id="ticketStatusChart" = JavaScript viittaa tähän. *@
                                            <canvas id="ticketStatusChart"></canvas>
                                        </div>
                                    </div>
                                }

                                @* Avoimet tiketit taulukkona. *@
                                @if (Model.RecentOpenTickets.Any())
                                {
                                    <div class="dash-card">
                                        <div class="dash-card-header">
                                            <i class="bi bi-list-check"></i>
                                            @* Admin: "Avoimet prioriteetin mukaan", Asiakas: "Omat tikettini". *@
                                            @(Model.IsAdmin ? L["Dash.Tickets.OpenByPriority"] : L["Dash.Tickets.Mine"])
                                        </div>
                                        <div class="dash-card-body p-0">
                                            <div class="table-responsive">
                                                @* dash-table = mukautettu taulukkotyyli. *@
                                                <table class="dash-table">
                                                    <thead>
                                                        <tr>
                                                            <th>#</th>
                                                            <th>@L["Dash.Col.Title"]</th>
                                                            @* Asiakas-sarake vain adminille. *@
                                                            @if (Model.IsAdmin) { <th>@L["Dash.Col.Customer"]</th> }
                                                            <th>@L["Dash.Col.Priority"]</th>
                                                            <th>@L["Dash.Col.Status"]</th>
                                                            <th>@L["Dash.Col.Created"]</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var t in Model.RecentOpenTickets)
                                                        {
                                                            <tr>
                                                                @* Tiketin ID linkkinä. link-subtle = muotoilu ilman alleviivauksia. *@
                                                                <td><a href="/Ticket/Details/@t.Id" class="link-subtle">#@t.Id</a></td>
                                                                @* text-truncate-cell = katkaistaan pitkä otsikko "...":lla. *@
                                                                <td class="text-truncate-cell"><a href="/Ticket/Details/@t.Id" class="link-subtle">@t.Title</a></td>
                                                                @if (Model.IsAdmin) { <td>@(t.Customer?.CompanyName ?? "-")</td> }
                                                                <td>
                                                                    @* badge-priority badge-critical/high/normal/low = mukautettu prioriteettibadge. *@
                                                                    <span class="badge-priority badge-@t.Priority.ToString().ToLower()">@PriorityLabel(t.Priority)</span>
                                                                </td>
                                                                <td>
                                                                    @* badge-status badge-status-open/inprogress/... = mukautettu tilabadge. *@
                                                                    <span class="badge-status badge-status-@t.Status.ToString().ToLower()">@StatusLabel(t.Status)</span>
                                                                </td>
                                                                <td class="text-nowrap">@t.CreatedAt.ToString("dd.MM.yyyy")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                        <div class="dash-card-footer">
                                            @* Linkki kaikkiin tiketteihin. *@
                                            <a href="/Ticket" class="btn-link-more"><i class="bi bi-arrow-right-circle"></i> @L["Dash.Tickets.All"]</a>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @* Tyhjä tila: kaikki kunnossa -ikoni. *@
                                    <div class="dash-card">
                                        <div class="dash-card-body text-center text-muted py-4">
                                            <i class="bi bi-check-circle display-4"></i>
                                            <p class="mt-2">@L["Dash.Tickets.None"]</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    break;

                case "invoices":
                    @* ── Widget: Laskut ─────────────────────────────── *@
                    <div class="widget mb-4" data-widget="invoices">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="widget-drag-handle"><i class="bi bi-grip-vertical"></i></span>
                        </div>

                        @* row g-4 = kaksipalstainen ruudukko erääntyvien ja erääntyneiden välillä. *@
                        <div class="row g-4">
                            @* Pian erääntyvät laskut (UpcomingDueInvoices). *@
                            @if (Model.UpcomingDueInvoices.Any())
                            {
                                <div class="col-lg-6">
                                    <div class="dash-card h-100">
                                        @* text-warning = keltainen otsikkoteksti (varoittava). *@
                                        <div class="dash-card-header text-warning">
                                            <i class="bi bi-calendar-event"></i> @L["Dash.Invoices.DueSoon"]
                                        </div>
                                        <div class="dash-card-body p-0">
                                            <ul class="invoice-list">
                                                @foreach (var inv in Model.UpcomingDueInvoices)
                                                {
                                                    @* Päivien laskenta: eräpäivä − tänään.
                                                       .Date = ohitetaan kellonaika, lasketaan vain päivät. *@
                                                    var daysLeft = (inv.DueDate.Date - DateTime.UtcNow.Date).Days;
                                                    <li>
                                                        <div class="inv-left">
                                                            @* Laskun numero linkkinä. *@
                                                            <span class="inv-num"><a href="/Invoice/Details/@inv.Id" class="link-subtle">@inv.InvoiceNumber</a></span>
                                                            @* Asiakkaan nimi vain adminille. *@
                                                            @if (Model.IsAdmin) { <span class="inv-customer">@(inv.Customer?.CompanyName ?? "-")</span> }
                                                        </div>
                                                        <div class="inv-right">
                                                            @* "N2" = kaksi desimaalia. *@
                                                            <span class="inv-amount">@inv.TotalAmount.ToString("N2") €</span>
                                                            @* daysLeft ≤ 2 → punainen (kiireellinen), muuten keltainen. *@
                                                            <span class="inv-days @(daysLeft <= 2 ? "text-danger" : "text-warning")">
                                                                @* daysLeft == 0 → "Tänään", muuten "X päivää". *@
                                                                @(daysLeft == 0 ? L["Common.Today"].Value : $"{daysLeft} {L["Common.Days"].Value}")
                                                            </span>
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                        <div class="dash-card-footer">
                                            <a href="/Invoice" class="btn-link-more"><i class="bi bi-arrow-right-circle"></i> @L["Dash.Invoices.All"]</a>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* Erääntyneet laskut (OverdueInvoices). *@
                            @if (Model.OverdueInvoices.Any())
                            {
                                <div class="col-lg-6">
                                    @* dash-card-danger = punainen reunakorostus. *@
                                    <div class="dash-card dash-card-danger h-100">
                                        <div class="dash-card-header text-danger">
                                            <i class="bi bi-exclamation-circle-fill"></i> @L["Dash.Invoices.Overdue"]
                                        </div>
                                        <div class="dash-card-body p-0">
                                            <ul class="invoice-list">
                                                @foreach (var inv in Model.OverdueInvoices)
                                                {
                                                    @* Erääntyneiden päivien laskenta: tänään − eräpäivä (negatiivinen arvo). *@
                                                    var overdueDays = (DateTime.UtcNow.Date - inv.DueDate.Date).Days;
                                                    <li>
                                                        <div class="inv-left">
                                                            <span class="inv-num"><a href="/Invoice/Details/@inv.Id" class="link-subtle">@inv.InvoiceNumber</a></span>
                                                            @if (Model.IsAdmin) { <span class="inv-customer">@(inv.Customer?.CompanyName ?? "-")</span> }
                                                        </div>
                                                        <div class="inv-right">
                                                            @* Erääntyneen laskun summa punaisella. *@
                                                            <span class="inv-amount text-danger">@inv.TotalAmount.ToString("N2") €</span>
                                                            @* Miinus-merkki kertoo että myöhässä (esim. "-3 päivää"). *@
                                                            <span class="inv-days text-danger">-@overdueDays @L["Common.Days"]</span>
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* Tyhjä tila: ei erääntyvää eikä myöhässä olevaa. *@
                            @if (!Model.UpcomingDueInvoices.Any() && !Model.OverdueInvoices.Any())
                            {
                                <div class="col-12">
                                    <div class="dash-card">
                                        <div class="dash-card-body text-center text-muted py-4">
                                            <i class="bi bi-check2-all display-4"></i>
                                            <p class="mt-2">@L["Dash.Invoices.None"]</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    break;

                case "calendar":
                    @* ── Widget: Kalenteri (tulevat varaukset) ────────── *@
                    <div class="widget mb-4" data-widget="calendar">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="widget-drag-handle"><i class="bi bi-grip-vertical"></i></span>
                        </div>
                        <div class="dash-card">
                            <div class="dash-card-header">
                                <i class="bi bi-calendar3"></i> @L["Dash.Calendar.Upcoming"]
                            </div>
                            <div class="dash-card-body p-0">
                                @if (!Model.UpcomingBookingSlots.Any())
                                {
                                    <div class="text-center text-muted py-4">
                                        <i class="bi bi-calendar-x display-4 d-block mb-2"></i>
                                        <p>@L["Dash.Calendar.NoneSoon"]</p>
                                    </div>
                                }
                                else
                                {
                                    <ul class="list-group list-group-flush">
                                        @foreach (var slot in Model.UpcomingBookingSlots)
                                        {
                                            @* Aikavälityypin väri ja ikoni switch-lausekkeella. *@
                                            var slotColor = slot.SlotType switch {
                                                BookingSlotType.Maintenance   => "warning",
                                                BookingSlotType.Consulting    => "primary",
                                                BookingSlotType.RemoteSupport => "info",
                                                _ => "secondary"
                                            };
                                            var slotIcon = slot.SlotType switch {
                                                BookingSlotType.Maintenance   => "bi-tools",
                                                BookingSlotType.Consulting    => "bi-person-workspace",
                                                BookingSlotType.RemoteSupport => "bi-display",
                                                _ => "bi-calendar"
                                            };

                                            <li class="list-group-item d-flex align-items-center gap-3 py-3">
                                                @* Päivämäärä-blokki: päivä + kuukauden lyhenne.
                                                   min-width:44px = tasainen leveys kaikille. *@
                                                <div class="text-center" style="min-width:44px">
                                                    <div class="fw-bold" style="font-size:.95rem; line-height:1.1">@slot.StartTime.ToString("dd", uiCulture)</div>
                                                    @* MMM = kolmikirjaiminen kuukausi (esim. "touk"). text-transform:uppercase. *@
                                                    <div class="text-muted" style="font-size:.7rem; text-transform:uppercase">@slot.StartTime.ToString("MMM", uiCulture)</div>
                                                </div>

                                                @* Pienikokoinen värillinen piste (8×8px) aikatyypin mukaan.
                                                   text-bg-@slotColor = Bootstrap 5.3 taustaväri. *@
                                                <span class="badge text-bg-@slotColor rounded-pill" style="width:8px; height:8px; padding:4px; flex-shrink:0"></span>

                                                @* Aikavälin tiedot. *@
                                                <div class="flex-grow-1">
                                                    <div class="fw-medium small">@slot.Title</div>
                                                    <div class="text-muted" style="font-size:.75rem">
                                                        <i class="bi @slotIcon me-1"></i>
                                                        @* HH:mm – HH:mm = alku- ja loppuaika. *@
                                                        @slot.StartTime.ToString("HH:mm") – @slot.EndTime.ToString("HH:mm")
                                                        @* Varauksia / kapasiteetti — näytetään vain jos varauksia on. *@
                                                        @if (slot.ActiveBookingsCount > 0)
                                                        {
                                                            <span class="ms-2">· @slot.ActiveBookingsCount/@slot.MaxCapacity @L["Dash.Calendar.Booked"]</span>
                                                        }
                                                    </div>
                                                </div>

                                                @* Varaa-painike tai "Täynnä"-badge. *@
                                                @if (slot.IsAvailable)
                                                {
                                                    <a asp-controller="Booking" asp-action="Book" asp-route-id="@slot.Id"
                                                       class="btn btn-outline-primary btn-sm">@L["Dash.Calendar.Book"]</a>
                                                }
                                                else
                                                {
                                                    <span class="badge text-bg-secondary">@L["Dash.Calendar.Fully"]</span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                            <div class="dash-card-footer">
                                <a asp-controller="Booking" asp-action="Index" class="btn-link-more">
                                    <i class="bi bi-arrow-right-circle"></i> @L["Dash.Calendar.Full"]
                                </a>
                            </div>
                        </div>
                    </div>
                    break;

                case "quickactions":
                    @* ── Widget: Pikalinkit ──────────────────────────── *@
                    <div class="widget mb-4" data-widget="quickactions">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="widget-drag-handle"><i class="bi bi-grip-vertical"></i></span>
                        </div>
                        <div class="dash-card">
                            <div class="dash-card-header">
                                <i class="bi bi-lightning-charge"></i> @L["Dash.Quick.Title"]
                            </div>
                            <div class="dash-card-body">
                                @* d-flex flex-wrap gap-2 = painikkeet rivittyvät tarvittaessa. *@
                                <div class="d-flex flex-wrap gap-2">
                                    @* Pikalinkit kaikille käyttäjille. *@
                                    <a asp-controller="Ticket" asp-action="Create" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-plus-lg me-1"></i>@L["Dash.Quick.NewTicket"]
                                    </a>
                                    <a asp-controller="Invoice" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-receipt me-1"></i>@L["Nav.Invoices"]
                                    </a>
                                    <a asp-controller="ServiceCatalog" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-grid me-1"></i>@L["Nav.Services"]
                                    </a>
                                    <a asp-controller="Booking" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-calendar3 me-1"></i>@L["Nav.Calendar"]
                                    </a>
                                    <a asp-controller="KnowledgeBase" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-book me-1"></i>@L["Nav.KnowledgeBase"]
                                    </a>
                                    @* Admin-kohtaiset pikalinkit. *@
                                    @if (Model.IsAdmin)
                                    {
                                        <a asp-controller="Customer" asp-action="Create" class="btn btn-outline-success btn-sm">
                                            <i class="bi bi-building-add me-1"></i>@L["Dash.Quick.NewCustomer"]
                                        </a>
                                        <a asp-controller="Report" asp-action="Index" class="btn btn-outline-info btn-sm">
                                            <i class="bi bi-bar-chart-line me-1"></i>@L["Nav.Reports"]
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    break;
            }
        }

    </div>
</div>

@* ── Scripts-osio ─────────────────────────────────────────────────── *@
@section Scripts {
    @* Chart.js CDN — piirtää kaaviot (donut + sparklines). *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    @* SortableJS CDN — drag-and-drop widgetijärjestyksen muuttamista varten. *@
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js"></script>

    @* ── Donut-kaavio: tikettien tilajakauma ── *@
    @* Renderöidään vain jos admin ja dataa on. *@
    @if (Model.IsAdmin && Model.TicketsByStatus.Any())
    {
        <script>
            (function () {
                @* Rakennetaan JS-taulukot Razor-datasta.
                   Model.TicketsByStatus = Dictionary<TicketStatus, int>.
                   .Keys → tilojen nimet (lokalisoituna): ['Avoin', 'Käsittelyssä', ...]
                   .Values → lukumäärät: [5, 3, 1, 2, 0]
                   string.Join(",", ...) = yhdistää listan pilkulla erotetuksi merkkijonoksi. *@
                const labels = [@Html.Raw(string.Join(",", Model.TicketsByStatus.Keys.Select(k => $"'{StatusLabel(k)}'")))]
                const data   = [@string.Join(",", Model.TicketsByStatus.Values)]
                @* Värit: sininen, keltainen, violetti, vihreä, harmaa. *@
                const colors = ['#3b82f6','#f59e0b','#8b5cf6','#22c55e','#6b7280']

                const ctx = document.getElementById('ticketStatusChart')
                if (!ctx) return; // turvacheck

                new Chart(ctx, {
                    type: 'doughnut', // donut-kaavio
                    data: {
                        labels,
                        datasets: [{
                            data,
                            backgroundColor: colors,
                            borderColor: '#ffffff',  // valkoiset erotusviivat sektoreiden välillä
                            borderWidth: 3,
                            hoverOffset: 8           // sektori nousee hiirellä
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,  // käyttää konttielementin korkeutta
                        cutout: '62%',               // donut-reikä 62% halkaisijasta
                        plugins: {
                            @* Legenda oikealla, pieni fontti. *@
                            legend: { position: 'right', labels: { color: '#475569', font: { size: 11 }, padding: 10, boxWidth: 12 } },
                            @* Tooltip: " Avoin: 5" -muotoilu. *@
                            tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.parsed}` } }
                        }
                    }
                })
            })()
        </script>
    }

    @* ── SortableJS drag-and-drop + layout edit mode ── *@
    <script>
        // editMode = onko muokkaustila päällä (widgettejä voi raahata).
        var editMode = false;
        // sortable = SortableJS-instanssi (alustetaan vasta ensimmäisen muokkausklikkauksen yhteydessä).
        var sortable = null;

        // toggleEditMode: vaihdetaan muokkaustila päälle/pois.
        function toggleEditMode() {
            editMode = !editMode;
            var root = document.getElementById('dashboardRoot');
            var btn  = document.getElementById('editLayoutBtn');

            if (editMode) {
                // Lisätään CSS-luokka joka näyttää raahauskahat ja muuttaa kursorin.
                root.classList.add('dashboard-edit-mode');
                btn.classList.add('active'); // korostaa painikkeen
                btn.title = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Dash.StopEditing"].Value));

                // Alustetaan SortableJS vasta kun muokkaustila avataan ensimmäistä kertaa.
                if (!sortable) {
                    sortable = Sortable.create(document.getElementById('widgetContainer'), {
                        handle: '.widget-drag-handle',  // raahaaminen vain kahvasta
                        animation: 150,                  // 150ms animaatio liikutettaessa
                        ghostClass: 'sortable-ghost',    // raahattu elementti puoliläpinäkyvä
                        chosenClass: 'sortable-chosen',  // valittu elementti korostettu
                        onEnd: saveLayout                // tallennetaan järjestys kun raahaaminen loppuu
                    });
                }
            } else {
                // Suljetaan muokkaustila.
                root.classList.remove('dashboard-edit-mode');
                btn.classList.remove('active');
                btn.title = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Dash.EditLayout"].Value));
            }
        }

        // saveLayout: tallentaa widgettien nykyisen järjestyksen palvelimelle.
        function saveLayout() {
            // Kerätään kaikkien widgettien data-widget-attribuutit järjestyksessä.
            var widgets = document.querySelectorAll('#widgetContainer .widget[data-widget]');
            var order = Array.from(widgets).map(w => w.dataset.widget);
            // AJAX POST /Home/SaveLayout — ei sivunlatausta, vain tallennus.
            fetch('/Home/SaveLayout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    // CSRF-suojaustunnus haetaan lomakkeesta tai meta-tagista.
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: JSON.stringify(order) // lista järjestyksessä, esim. ["kpi","tickets","invoices"]
            });
        }

        // getAntiForgeryToken: hakee CSRF-tunnuksen joko lomakekentästä tai meta-tagista.
        function getAntiForgeryToken() {
            var el = document.querySelector('input[name="__RequestVerificationToken"]');
            if (el) return el.value;
            var meta = document.querySelector('meta[name="__RequestVerificationToken"]');
            return meta ? meta.content : '';
        }
    </script>

    @* Anti-forgery token SaveLayout-AJAX-kutsulle.
       Renderöidään piilokenttänä sivulle (getAntiForgeryToken() löytää sen). *@
    @Html.AntiForgeryToken()

    <script>
        // ── Sparkline-kaaviot (KPI-korttien trendiviivakaaviot) ─────────────
        (function () {
            // Turvacheck: Chart.js ei ole ladattu.
            if (typeof Chart === 'undefined') return;

            // Haetaan CSS-muuttujiinperustuvat värit sparklineille.
            // getComputedStyle → lukee :root CSS-muuttujan arvon.
            // .trim() = poistetaan mahdolliset etu- ja jälkivälilyönnit.
            // || '#fallback' = jos CSS-muuttujaa ei löydy, käytetään kovakoodattua väriä.
            var toneColor = {
                info:    getComputedStyle(document.documentElement).getPropertyValue('--info-fg').trim()    || '#2563eb',
                success: getComputedStyle(document.documentElement).getPropertyValue('--success-fg').trim() || '#16a34a',
                warning: getComputedStyle(document.documentElement).getPropertyValue('--warning-fg').trim() || '#d97706',
                danger:  getComputedStyle(document.documentElement).getPropertyValue('--danger-fg').trim()  || '#dc2626',
                neutral: getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#64748b',
                purple:  getComputedStyle(document.documentElement).getPropertyValue('--purple-fg').trim()  || '#7c3aed'
            };

            // Haetaan kaikki sparkline-canvas-elementit (KpiCard-komponentti lisää nämä).
            document.querySelectorAll('canvas[data-sparkline]').forEach(function (c) {
                try {
                    // JSON.parse purkaa data-sparkline-attribuutin JavaScript-taulukoksi.
                    var data = JSON.parse(c.getAttribute('data-sparkline'));
                    // Tarvitaan vähintään 2 datapistettä viivan piirtämiseen.
                    if (!Array.isArray(data) || data.length < 2) return;
                    // Väri data-tone-attribuutista (esim. "warning").
                    var tone = c.getAttribute('data-tone') || 'neutral';
                    var color = toneColor[tone] || toneColor.neutral;

                    new Chart(c, {
                        type: 'line',
                        data: {
                            // X-akseliksi yksinkertaiset indeksit (0, 1, 2...) — ei näytetä.
                            labels: data.map(function (_, i) { return i; }),
                            datasets: [{
                                data: data,
                                borderColor: color,
                                backgroundColor: color + '22', // 22 hex = 13% läpinäkyvyys
                                tension: 0.35,      // kaareva viiva
                                fill: true,         // täytetään alueen alla
                                pointRadius: 0,     // ei pisteitä
                                borderWidth: 1.5    // ohut viiva
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend:  { display: false },  // ei legendaa
                                tooltip: { enabled: false }   // ei tooltipejä
                            },
                            scales: {
                                x: { display: false },  // piilotetaan akselit
                                y: { display: false }
                            },
                            animation: false  // ei animaatiota (sparkline on pienikokoinen)
                        }
                    });
                } catch (e) { /* noop — virhe ei kaada muuta sivua */ }
            });
        })();

        // ── Layout preset -hallinta ────────────────────────────────────────────
        (function () {
            // Haetaan tallennettu preset localStorage:sta.
            // try/catch = localStorage voi epäonnistua yksityistilassa tai rajoitetuissa selaimissa.
            var saved = null;
            try { saved = localStorage.getItem('hakatech-preset'); } catch (e) {}

            var preset = saved || 'default'; // oletus: "default"
            applyPreset(preset);

            // Merkitään tallennettu preset valituksi.
            // preset.charAt(0).toUpperCase() + preset.slice(1) = "default" → "Default" (isolla alkukirjaimella).
            var radio = document.getElementById('preset' + preset.charAt(0).toUpperCase() + preset.slice(1));
            if (radio) radio.checked = true;

            // Kuunnellaan kaikkien radio-nappien muutoksia.
            document.querySelectorAll('input[name="dashPreset"]').forEach(function (r) {
                r.addEventListener('change', function () {
                    if (r.checked) {
                        applyPreset(r.value);
                        try { localStorage.setItem('hakatech-preset', r.value); } catch (e) {}
                    }
                });
            });

            // applyPreset: lisää body:lle preset-XXX-luokan joka vaikuttaa layoutiin.
            function applyPreset(p) {
                // Poistetaan kaikki preset-luokat ensin.
                document.body.classList.remove('preset-default', 'preset-compact', 'preset-focus');
                // Lisätään valittu.
                document.body.classList.add('preset-' + p);
            }
        })();
    </script>
}

@* ── @functions-lohko: apufunktiot lokalisoituihin nimiin ──────────── *@
@functions {
    @* Nämä funktiot käytetään sekä HTML-osiossa (badge-teksteissä)
       että JavaScript-osiossa (kaavion label-arrayssa).
       Siksi ne on määritelty @functions-lohkossa — eivät ole skoopattu
       pelkästään @{}-koodilohkoon. *@
    string PriorityLabel(TicketPriority p) => L[$"TicketPriority.{p}"].Value;
    string StatusLabel(TicketStatus s) => L[$"TicketStatus.{s}"].Value;
}
