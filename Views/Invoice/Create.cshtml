@*
    Invoice/Create.cshtml — Uuden laskun luontilomake (vain admin).

    Rakenne:
      - form-grid: kaksipalstainen asettelu (pääsisältö + sivupalkki)
      - Pääsisältö: laskurivit dynaamisesti + muistiinpanot
      - Sivupalkki: metatiedot (asiakas, laskunumero, päivät, ALV-kanta)

    Laskurivit:
      - Rivejä voi lisätä "Lisää rivi" -painikkeella
      - Rivejä voi poistaa roskakoripainikkeella (min. 1 rivi säilyy aina)
      - Lomakekenttien nimi seuraa mallistakiinnikettä Lines[i].Description jne.
      - JavaScript laskee rivin summan (määrä × hinta) ja kokonaissummat reaaliaikaisesti

    ALV-laskelma:
      - VatRate = kerroin välillä 0–1 (esim. 0.255 = 25,5 %)
      - ALV-summa = veroton × VatRate
      - Loppusumma = veroton + ALV

    Yhteys: InvoiceController.Create (GET = esitäytetty lomake, POST = tallennetaan).
*@

@* Malli sisältää: CustomerId, CustomerOptions, InvoiceNumber, InvoiceDate, DueDate,
   VatRate, Notes, Lines (lista InvoiceLineFormViewModel-olioita, joissa Description,
   Quantity ja UnitPrice). *@
@model HakaTech.Portal.Models.ViewModels.InvoiceCreateViewModel

@{
    @* Sivun otsikko — näytetään selaimen välilehtipalkkiin. *@
    ViewData["Title"] = L["Invoice.Create.Title"].Value;

    @* Murupolku: Laskut → Uusi lasku.
       Lista (string otsikko, string? linkki) -tupleista.
       null = viimeinen taso (ei linkkiä, vain teksti). *@
    ViewData["Breadcrumbs"] = new List<(string, string?)>
    {
        (L["Invoice.Index.Title"].Value, Url.Action("Index", "Invoice")),
        (L["Invoice.Create.Title"].Value, null)
    };

    @* Tallennetaan käyttöliittymän kieliasetuksen nimi JavaScript-muuttujaa varten.
       CurrentUICulture = esim. "fi-FI" tai "en-US".
       Käytetään toLocaleString(culture, ...) -kutsussa valuuttamuotoiluun. *@
    var uiCulture = System.Globalization.CultureInfo.CurrentUICulture;
}

@* Sivun otsikkorivi: vasen puoli = nimi + aliotsikko, oikea puoli = painikkeet.
   page-header on projektin oma CSS-luokka johdonmukaiseen ylätunnisteeseen. *@
<header class="page-header">
    <div class="page-header-main">
        @* bi-receipt = kuittiikonin Bootstrap Icons -luokka. *@
        <h1 class="page-header-title"><i class="bi bi-receipt"></i> @L["Invoice.Create.Heading"]</h1>
        <p class="page-header-sub">@L["Invoice.Create.Title"]</p>
    </div>
    <div class="page-header-actions">
        @* Takaisin laskulistaan — variant-ghost = kehysttömän linkkipainike. *@
        <a asp-action="Index" class="btn-lnr variant-ghost size-sm">
            <i class="bi bi-arrow-left"></i> @L["UI.Button.Back"]
        </a>
        @* Tallenna-painike. form="invoice-form" = tämä painike lähettää alempana
           olevan <form>-lomakkeen, vaikka painike on lomakkeen ULKOPUOLELLA
           (HTML-standardi: submit-painike voi viitata lomakkeeseen id:n kautta).
           variant-primary = korostettu sininen painike. *@
        <button type="submit" form="invoice-form" class="btn-lnr variant-primary size-sm">
            <i class="bi bi-check-lg"></i> @L["Invoice.Create.Submit"]
        </button>
    </div>
</header>

@* Lomake. id="invoice-form" mahdollistaa submit-painikkeen lomakkeen ulkopuolella.
   asp-action="Create" → POST /Invoice/Create.
   AntiForgery-token lisätään automaattisesti Tag Helperillä. *@
<form asp-action="Create" method="post" id="invoice-form">
    @* Mallivirheyhteenveto: näyttää palvelimelta tulevat yleiset virheet (esim.
       laskunumero jo käytössä). tone-danger = punainen kehys projektin tyylissä.
       padding/margin ovat inline-tyylejä korttikorkeuden säätöön. *@
    <div asp-validation-summary="ModelOnly" class="card-lnr tone-danger" style="padding: 12px 16px; margin-bottom: 16px; color: var(--danger-fg);"></div>

    @* form-grid = projektin kaksipalstainen CSS-asettelu:
       form-grid-main = leveä vasen sarake (pääsisältö)
       form-grid-aside = kapea oikea sarake (metatiedot / sivupalkki) *@
    <div class="form-grid">

        @* ── VASEN SARAKE: laskurivit + muistiinpanot ── *@
        <div class="form-grid-main">

            @* form-section + legend = visuaalisesti ryhmitelty osio selkeällä otsikolla. *@
            <fieldset class="form-section">
                <legend>@L["UI.Form.Section.Main"]</legend>

                @* Pienen alaotsikon ikoni + teksti laskuriviosiolle.
                   font-size:.85rem = pienempi koko kuin h6 normaalisti.
                   var(--text-secondary) = CSS-muuttuja projektin harmaalle värille. *@
                <h6 class="fw-bold mb-2" style="font-size:.85rem; color: var(--text-secondary);">
                    <i class="bi bi-list-ul me-1"></i>@L["Invoice.Create.Lines"]
                </h6>

                @* table-responsive = Bootstrap: taulukkoon vaakasuuntainen vierityspalkki
                   jos se ei mahdu näytölle (mobiilioptimointi). *@
                <div class="table-responsive mb-2">
                    @* table-sm = tiivistää solujen paddingit.
                       table-lnr = projektin oma taulukkotyyli (reunukset, värit). *@
                    <table class="table table-sm table-lnr" id="lines-table">
                        <thead>
                            <tr>
                                <th>@L["Invoice.Create.Col.Description"]</th>
                                @* width: kiinteä leveys — estää sarakkeen kasvamasta tarpeettomasti. *@
                                <th style="width:100px">@L["Invoice.Create.Col.Quantity"]</th>
                                <th style="width:130px">@L["Invoice.Create.Col.UnitPrice"]</th>
                                @* text-end = oikealle tasattu — rahallisten arvojen standardi. *@
                                <th style="width:130px" class="text-end">@L["Invoice.Create.Col.LineTotal"]</th>
                                @* Tyhjä sarakkeen otsikko poistopainikkeelle. *@
                                <th style="width:50px"></th>
                            </tr>
                        </thead>

                        @* id="lines-body" — JavaScript löytää rivit tällä ID:llä. *@
                        <tbody id="lines-body">
                            @* Esirenderöidyt rivit mallin perusteella (GET-latauksessa yleensä 1 tyhjä rivi).
                               @for käy indeksillä 0..Count-1 jotta voimme käyttää i kenttien nimissä. *@
                            @for (int i = 0; i < Model.Lines.Count; i++)
                            {
                                @* line-row = CSS-luokka jolla JavaScript tunnistaa rivit. *@
                                <tr class="line-row">
                                    <td>
                                        @* name="Lines[0].Description" — ASP.NET MVC:n model binding
                                           odottaa tätä nimeämiskonventiota kerätäkseen listaan.
                                           line-desc = JavaScript tunnistaa kentän tällä luokalla.
                                           value=... esitäyttää mahdollisen POST-virhepalautuksen jälkeen. *@
                                        <input name="Lines[@i].Description" type="text"
                                               class="form-control form-control-sm line-desc"
                                               value="@Model.Lines[i].Description"
                                               placeholder="@L["Invoice.Create.LineDescPlaceholder"]" />
                                    </td>
                                    <td>
                                        @* step="0.01" = sallii desimaalit (esim. 2,5 tuntia).
                                           min="0.01" = estää nollan tai negatiiviset määrät. *@
                                        <input name="Lines[@i].Quantity" type="number"
                                               class="form-control form-control-sm line-qty"
                                               value="@Model.Lines[i].Quantity" step="0.01" min="0.01" />
                                    </td>
                                    <td>
                                        @* min="0" = sallii nollahinnoittelun (esim. ilmaiset tuotteet).
                                           step="0.01" = senttitarkkuus. *@
                                        <input name="Lines[@i].UnitPrice" type="number"
                                               class="form-control form-control-sm line-price"
                                               value="@Model.Lines[i].UnitPrice" step="0.01" min="0" />
                                    </td>
                                    @* Rivin summa. Aluksi 0,00 € — JavaScript päivittää arvon heti.
                                       font-variant-numeric: tabular-nums = monolevyiset numerot
                                       jottei summa hypi sivusuunnassa arvojen vaihtuessa. *@
                                    <td class="text-end align-middle line-total fw-semibold" style="font-variant-numeric: tabular-nums;">0,00 €</td>
                                    <td class="text-center align-middle">
                                        @* Poistopainike: type="button" = EI lähetä lomaketta.
                                           btn-remove-line = JavaScript kiinnittää tapahtumankuuntelijan
                                           tähän luokkaan. *@
                                        <button type="button" class="btn-lnr variant-ghost size-sm btn-remove-line"
                                                title="@L["Invoice.Create.RemoveLine"]">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* "Lisää rivi" -painike. type="button" = ei lähetä lomaketta.
                   variant-subtle = vaalea/tausta, ei niin korostettu kuin primary.
                   mb-3 = alapuolelle 16px marginaali. *@
                <button type="button" id="btn-add-line" class="btn-lnr variant-subtle size-sm mb-3">
                    <i class="bi bi-plus-lg"></i> @L["Invoice.Create.AddLine"]
                </button>

                @* Yhteenvetopaneeli: veroton/ALV/yhteensä.
                   justify-content-end = tasataan oikealle reunaan. *@
                <div class="d-flex justify-content-end mt-3">
                    @* min-width: 260px varmistaa että summien rivit eivät katkea. *@
                    <div class="meta-list" style="min-width: 260px;">
                        @* meta-list-row = projektin oma tyyli avain: arvo -riveille. *@
                        <div class="meta-list-row">
                            <span class="meta-list-key">@L["Invoice.Create.Subtotal"]</span>
                            @* id="summary-subtotal" — JavaScript kirjoittaa lasketun verottoman
                               summan tähän elementtiin. mono = monolevyinen fontti numeroille. *@
                            <span class="meta-list-val mono" id="summary-subtotal">0,00 €</span>
                        </div>
                        <div class="meta-list-row">
                            <span class="meta-list-key">@L["Invoice.Create.Vat"]</span>
                            @* id="summary-vat" — ALV-summa päivittyy JavaScriptissä. *@
                            <span class="meta-list-val mono" id="summary-vat">0,00 €</span>
                        </div>
                        @* font-weight: 700 = lihavoitu loppusummarivi. *@
                        <div class="meta-list-row" style="font-weight: 700;">
                            <span class="meta-list-key">@L["Common.Total"]</span>
                            @* var(--accent-600) = projektin pääväri (sininen) loppusummalle.
                               id="summary-total" — JavaScript päivittää veroton + ALV. *@
                            <span class="meta-list-val mono" id="summary-total" style="color: var(--accent-600);">0,00 €</span>
                        </div>
                    </div>
                </div>
            </fieldset>

            @* Muistiinpano-osio. *@
            <fieldset class="form-section">
                @* legend käyttää muistiinpanon paikkamerkkitekstiä — pieni poikkeama,
                   legend voisi olla myös erillinen lokalisointiavain. *@
                <legend>@L["Invoice.Create.NotesPlaceholder"]</legend>
                <div class="form-field">
                    <label asp-for="Notes" class="form-field-label"></label>
                    @* rows="3" = kolmirivinen tekstialue. *@
                    <textarea asp-for="Notes" class="form-control" id="invoice-notes"
                              rows="3" placeholder="@L["Invoice.Create.NotesPlaceholder"]"></textarea>
                </div>
            </fieldset>
        </div>

        @* ── OIKEA SARAKE: metatiedot ── *@
        @* <aside> on semanttisesti sivusiältö — apusisältö pääsisällön lisänä. *@
        <aside class="form-grid-aside">
            <fieldset class="form-section">
                <legend>@L["UI.Form.Section.Meta"]</legend>

                @* Asiakasvalitsin.
                   asp-items="Model.CustomerOptions" = Tag Helper generoi <option>-elementit
                   SelectList-kokoelmasta (Value=Id, Text=CompanyName).
                   id="invoice-customer" = käytetään tarvittaessa JS-validoinnissa. *@
                <div class="form-field">
                    <label asp-for="CustomerId" class="form-field-label"></label>
                    <select asp-for="CustomerId" asp-items="Model.CustomerOptions"
                            id="invoice-customer" class="form-select">
                        @* Oletusvalinta (ei valintaa) arvo 0 — kontrolleri validoi CustomerId > 0. *@
                        <option value="0">@L["Invoice.Create.SelectCustomer"]</option>
                    </select>
                    <span asp-validation-for="CustomerId" class="form-field-error"></span>
                </div>

                @* Laskunumero. Kontrolleri esitäyttää seuraavan vapaan numeron (esim. INV-0042).
                   Admin voi muuttaa sen haluamakseen. *@
                <div class="form-field">
                    <label asp-for="InvoiceNumber" class="form-field-label"></label>
                    <input asp-for="InvoiceNumber" class="form-control" id="invoice-number" />
                    <span asp-validation-for="InvoiceNumber" class="form-field-error"></span>
                </div>

                @* Laskupäivä. type="date" = selaimen natiivia päivämäärävalitsin.
                   value="yyyy-MM-dd" = HTML date-kenttä vaatii ISO 8601 -muodon. *@
                <div class="form-field">
                    <label asp-for="InvoiceDate" class="form-field-label"></label>
                    <input asp-for="InvoiceDate" type="date" class="form-control" id="invoice-date"
                           value="@Model.InvoiceDate.ToString("yyyy-MM-dd")" />
                </div>

                @* Eräpäivä. Kontrolleri esitäyttää oletuksena 14 tai 30 päivää laskupäivästä. *@
                <div class="form-field">
                    <label asp-for="DueDate" class="form-field-label"></label>
                    <input asp-for="DueDate" type="date" class="form-control" id="invoice-due"
                           value="@Model.DueDate.ToString("yyyy-MM-dd")" />
                </div>

                @* ALV-kanta (arvonlisäveroprosentti desimaalina).
                   step="0.001" = kolmen desimaalin tarkkuus (esim. 0.255 = 25,5 %).
                   max="1" = enintään 100 % (ei järkevässä käytössä ylity).
                   value="0.000" = muotoilu Razor-puolella kolme desimaalia näkyviin. *@
                <div class="form-field">
                    <label asp-for="VatRate" class="form-field-label"></label>
                    <input asp-for="VatRate" type="number" step="0.001" min="0" max="1"
                           class="form-control" id="invoice-vat"
                           value="@Model.VatRate.ToString("0.000")" />
                    @* form-field-hint = harmaa ohjeteksti kentän alla
                       (esim. "Syötä desimaalina: 0.255 = 25,5 %"). *@
                    <span class="form-field-hint">@L["Invoice.Create.VatHint"]</span>
                </div>
            </fieldset>
        </aside>
    </div>
</form>

@* Scripts-osio: ladataan validointikirjastot ja lomakkeen JavaScript.
   @section Scripts {} = lisätään _Layout.cshtml:n Scripts-alueelle,
   joka sijaitsee </body>-tagin yläpuolella. *@
@section Scripts {
@* _ValidationScriptsPartial lataa jquery.validate.min.js + jquery.validate.unobtrusive.min.js
   jotta asp-validation-for-attribuutit toimivat asiakaspuolella. *@
@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

<script>
@* IIFE (Immediately Invoked Function Expression): (function(){...})()
   Sulkee kaiken muuttujat paikalliseen scopeen — ei saastuta globaalia window-objektia.
   Näin useat skriptit samalla sivulla eivät törmää toistensa muuttujiin. *@
(function () {
    @* culture = "fi-FI" tai "en-US" — Razor kirjoittaa C#-arvon JS-muuttujaan.
       Html.Raw() estää < > & -merkkien HTML-enkoodauksen JSON-merkkijonossa.
       JsonSerializer.Serialize = turvallinen tapa tuottaa JSON-merkkijono,
       lisää automaattisesti lainausmerkit ja escapettaa erikoismerkit. *@
    const culture = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(uiCulture.Name));

    @* T = lokalisoidut tekstit JavaScriptille.
       Sama Json-serialize-Html.Raw -kaava kuin culture-muuttujalle. *@
    const T = {
        lineDescPlaceholder: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Invoice.Create.LineDescPlaceholder"].Value)),
        removeLine:          @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Invoice.Create.RemoveLine"].Value))
    };

    @* rowIndex = seuraavan uuden rivin indeksi.
       Alustetaan palvelimelta renderoitujen rivien lukumäärällä,
       jottei uusi rivi ylikirjoita olemassa olevan rivin nimeä. *@
    let rowIndex = @Model.Lines.Count;

    @* fmt(n) = muotoilee luvun valuuttamerkkijonoksi käyttöliittymän kulttuurin mukaan.
       toLocaleString = JS:n sisäänrakennettu numero → merkkijono -muunnos.
       style:'currency', currency:'EUR' → "1 250,00 €" (fi-FI) tai "€1,250.00" (en-US). *@
    function fmt(n) {
        return n.toLocaleString(culture, { style: 'currency', currency: 'EUR' });
    }

    @* recalc() = laskee kaikki rivin summat ja kokonaissummat uudelleen.
       Kutsutaan aina kun määrä, yksikköhinta tai ALV-kanta muuttuu. *@
    function recalc() {
        let sub = 0; // veroton yhteissumma (kertyvä)

        @* querySelectorAll palauttaa kaikki .line-row -elementit #lines-body:n sisältä.
           forEach(row, i) käy jokaisen rivin läpi indeksillä i = rivin järjestysnumero DOM:ssa. *@
        document.querySelectorAll('#lines-body .line-row').forEach((row, i) => {

            @* Uudelleennimetään kenttien name-attribuutit vastaamaan nykyistä järjestystä.
               Tarvitaan kun rivejä poistetaan välistä — muuten indeksit voivat jäädä aukkoisiksi
               (esim. Lines[0], Lines[2]) ja ASP.NET MVC:n model binding hylkää ne.
               /Lines\[\d+\]/ = regex: "Lines[" + yksi tai useampi numero + "]"
               Korvataan Lines[${i}]:llä = oikea järjestysnumero. *@
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/Lines\[\d+\]/, `Lines[${i}]`);
            });

            @* Luetaan määrä ja yksikköhinta. parseFloat muuntaa merkkijonon liukuluvuksi.
               || 0 = jos kenttä on tyhjä tai ei ole numero, käytetään nollaa (ei NaN-virheitä). *@
            const qty   = parseFloat(row.querySelector('.line-qty').value)   || 0;
            const price = parseFloat(row.querySelector('.line-price').value)  || 0;
            const total = qty * price; // rivin summa
            sub += total;              // lisätään verottomaan kokonaissummaan

            @* Päivitetään rivin summan näyttö käyttäen fmt()-valuuttamuotoilua. *@
            row.querySelector('.line-total').textContent = fmt(total);
        });

        @* Haetaan ALV-kanta-kenttä. || 0 = jos tyhjä, ALV on 0 %. *@
        const vatRate = parseFloat(document.getElementById('invoice-vat').value) || 0;
        const vat     = sub * vatRate; // ALV-summa euromääräisenä

        @* Päivitetään yhteenvetopaneelin kolme kenttää. *@
        document.getElementById('summary-subtotal').textContent = fmt(sub);
        document.getElementById('summary-vat').textContent      = fmt(vat);
        document.getElementById('summary-total').textContent    = fmt(sub + vat);
    }

    @* addRow() = lisää uuden tyhjän laskurivin taulukkoon. *@
    function addRow() {
        @* idx = tämän uuden rivin indeksi. rowIndex++ = ensin käytä arvo, sitten kasvata. *@
        const idx  = rowIndex++;

        @* Luodaan uusi <tr>-elementti ohjelmallisesti. *@
        const tr   = document.createElement('tr');
        tr.className = 'line-row';

        @* innerHTML = asetetaan koko rivin HTML-sisältö template literal -merkkijonolla.
           ${idx} = indeksi interpoloidaan merkkijonoon (korvaa @i Razor-koodissa).
           ${T.lineDescPlaceholder} ja ${T.removeLine} = JS-puolella lokalisoidut tekstit.
           Kaikki kentät identtiset palvelinpuolen Razor-logiikan kanssa. *@
        tr.innerHTML = `
            <td><input name="Lines[${idx}].Description" type="text"
                 class="form-control form-control-sm line-desc" placeholder="${T.lineDescPlaceholder}" /></td>
            <td><input name="Lines[${idx}].Quantity" type="number"
                 class="form-control form-control-sm line-qty" value="1" step="0.01" min="0.01" /></td>
            <td><input name="Lines[${idx}].UnitPrice" type="number"
                 class="form-control form-control-sm line-price" value="0" step="0.01" min="0" /></td>
            <td class="text-end align-middle line-total fw-semibold" style="font-variant-numeric: tabular-nums;">0,00 €</td>
            <td class="text-center align-middle">
                <button type="button" class="btn-lnr variant-ghost size-sm btn-remove-line" title="${T.removeLine}">
                    <i class="bi bi-trash"></i>
                </button>
            </td>`;

        @* Lisätään rivi taulukon loppuun. *@
        document.getElementById('lines-body').appendChild(tr);

        @* Siirretään fokus uuden rivin kuvauskenttään — parantaa käytettävyyttä
           (käyttäjä voi kirjoittaa suoraan lähettämättä lomaketta). *@
        tr.querySelector('.line-desc').focus();

        @* Kiinnitetään tapahtumankuuntelijat uuteen riviin (sama kuin vanhoillekin riveille). *@
        bindRow(tr);

        @* Päivitetään summat heti (uusi rivi voi muuttaa lukumäärää). *@
        recalc();
    }

    @* bindRow(row) = kiinnittää tapahtumankuuntelijat yhdelle riville.
       Kutsutaan sekä esirenderöidyille riveille että dynaamisesti lisätyille. *@
    function bindRow(row) {
        @* Kuuntele 'input'-tapahtumaa (joka näppäinpainallus) määrä- ja hintakentissä.
           querySelectorAll('.line-qty, .line-price') = molemmat kentät yhdellä haulla. *@
        row.querySelectorAll('.line-qty, .line-price').forEach(el =>
            el.addEventListener('input', recalc));

        @* Poistopainike: klikkaus poistaa rivin DOM:sta.
           Suoja: jos rivejä on vain yksi, ei poisteta (lasku tarvitsee ≥ 1 rivin). *@
        row.querySelector('.btn-remove-line').addEventListener('click', () => {
            if (document.querySelectorAll('#lines-body .line-row').length > 1) {
                row.remove();   // poistetaan rivi DOM:sta
                recalc();       // päivitetään summat
            }
        });
    }

    @* Kiinnitetään tapahtumankuuntelijat kaikkiin palvelimen renderöimiin riveihin.
       (forEach kutsuu bindRow:ia jokaiselle .line-row -elementille heti sivun latautuessa.) *@
    document.querySelectorAll('#lines-body .line-row').forEach(bindRow);

    @* "Lisää rivi" -painike → addRow-funktio. *@
    document.getElementById('btn-add-line').addEventListener('click', addRow);

    @* ALV-kenttä → recalc aina kun arvo muuttuu (ei tarvitse uutta riviä). *@
    document.getElementById('invoice-vat').addEventListener('input', recalc);

    @* Ajetaan recalc heti sivun latautuessa, jottei esirenderöityjen rivien
       "0,00 €" -placeholder jää paikoilleen (arvojen pitää näkyä oikein heti). *@
    recalc();
})(); @* IIFE:n sulkeminen ja välitön kutsu. *@
</script>
}
