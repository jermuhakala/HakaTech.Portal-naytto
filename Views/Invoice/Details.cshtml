@*
    Invoice/Details.cshtml — Laskun detaljisivu. Näyttää laskurivit,
    summat (sis. ALV), liitteet ja PDF-latauspainikkeen. Adminilla on
    myös tilanvaihtopainikkeet (esim. "Merkitse maksetuksi").
*@
@model HakaTech.Portal.Models.Domain.Invoice
@using HakaTech.Portal.Models.Domain
@using HakaTech.Portal.Models.ViewModels
@{
    ViewData["Title"] = Model.InvoiceNumber;
    ViewData["Breadcrumbs"] = new List<(string, string?)>
    {
        (L["Invoice.Index.Title"].Value, Url.Action("Index", "Invoice")),
        (Model.InvoiceNumber, null)
    };
    bool isAdmin       = (bool)(ViewBag.IsAdmin ?? false);
    var statusModel    = ViewBag.StatusModel as InvoiceStatusViewModel;
    var history        = ViewBag.CustomerHistory as List<Invoice> ?? new List<Invoice>();

    string StatusLabel(InvoiceStatus s) => L[$"InvoiceStatus.{s}"].Value;
    static string BadgeCss(InvoiceStatus s) => s switch {
        InvoiceStatus.Paid    => "bg-success",
        InvoiceStatus.Overdue => "bg-danger",
        InvoiceStatus.Sent    => "bg-primary",
        InvoiceStatus.Unpaid  => "bg-warning text-dark",
        _                     => "bg-secondary"
    };
    static string HistoryCss(InvoiceStatus s) => s switch {
        InvoiceStatus.Paid    => "text-success",
        InvoiceStatus.Overdue => "text-danger",
        InvoiceStatus.Sent    => "text-primary",
        InvoiceStatus.Unpaid  => "text-warning",
        _                     => "text-muted"
    };
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@L["Invoice.Index.Title"]</a></li>
        @if (isAdmin && Model.Customer is not null)
        {
            <li class="breadcrumb-item">
                <a asp-controller="Customer" asp-action="Details" asp-route-id="@Model.CustomerId">
                    @Model.Customer.CompanyName
                </a>
            </li>
        }
        <li class="breadcrumb-item active">@Model.InvoiceNumber</li>
    </ol>
</nav>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-3">
                <div>
                    <h5 class="mb-0">
                        <i class="bi bi-receipt me-2"></i>@Model.InvoiceNumber
                    </h5>
                    <small class="text-muted">@(Model.Customer?.CompanyName)</small>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge @BadgeCss(Model.Status) fs-6">@StatusLabel(Model.Status)</span>
                    <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary rounded-pill">
                        <i class="bi bi-file-earmark-pdf me-1"></i> @L["Invoice.Details.DownloadPdf"]
                    </a>
                </div>
            </div>
            <div class="card-body">

                <div class="row mb-3">
                    <div class="col-sm-6">
                        <dl class="row mb-0 small">
                            <dt class="col-5">@L["Invoice.Details.InvoiceDate"]</dt>
                            <dd class="col-7">@Model.InvoiceDate.ToString("dd.MM.yyyy")</dd>
                            <dt class="col-5">@L["Invoice.Col.DueDate"]</dt>
                            <dd class="col-7 @(Model.DueDate < DateTime.Today && Model.Status != InvoiceStatus.Paid ? "text-danger fw-semibold" : "")">
                                @Model.DueDate.ToString("dd.MM.yyyy")
                            </dd>
                            @if (Model.PaidAt.HasValue)
                            {
                                <dt class="col-5">@L["Invoice.Details.PaidAt"]</dt>
                                <dd class="col-7 text-success fw-semibold">@Model.PaidAt.Value.ToLocalTime().ToString("dd.MM.yyyy")</dd>
                            }
                        </dl>
                    </div>
                    <div class="col-sm-6">
                        <dl class="row mb-0 small">
                            <dt class="col-5">@L["Invoice.Details.VatRate"]</dt>
                            <dd class="col-7">@((Model.VatRate * 100).ToString("0.#")) %</dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="alert alert-secondary small mb-3">
                        <i class="bi bi-sticky me-1"></i>@Model.Notes
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@L["Invoice.Create.Col.Description"]</th>
                                <th class="text-end" style="width:90px">@L["Invoice.Create.Col.Quantity"]</th>
                                <th class="text-end" style="width:120px">@L["Invoice.Create.Col.UnitPrice"]</th>
                                <th class="text-end" style="width:120px">@L["Common.Total"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines)
                            {
                                <tr>
                                    <td>@line.Description</td>
                                    <td class="text-end">@line.Quantity.ToString("G")</td>
                                    <td class="text-end">@line.UnitPrice.ToString("C")</td>
                                    <td class="text-end fw-semibold">@((line.Quantity * line.UnitPrice).ToString("C"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end">@L["Invoice.Details.SubTotal"]</td>
                                <td class="text-end">@Model.SubTotal.ToString("C")</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end">
                                    @L["Invoice.Create.Vat"] @((Model.VatRate * 100).ToString("0.#")) %
                                </td>
                                <td class="text-end">@Model.VatAmount.ToString("C")</td>
                            </tr>
                            <tr class="fw-bold fs-6">
                                <td colspan="3" class="text-end">@L["Common.Total"]</td>
                                <td class="text-end text-primary">@Model.TotalAmount.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <i class="bi bi-paperclip me-2"></i>@L["Invoice.Details.Attachments"]
                <span class="badge bg-secondary ms-1">@Model.Attachments.Count</span>
            </div>

            @if (Model.Attachments.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var a in Model.Attachments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <div class="text-truncate" style="max-width:70%">
                                <i class="bi bi-file-earmark-pdf me-2 text-muted"></i>
                                <a asp-action="DownloadAttachment" asp-route-id="@a.Id"
                                   class="text-decoration-none">@a.FileName</a>
                                <small class="text-muted ms-2 d-none d-sm-inline">
                                    @a.UploadedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </small>
                            </div>
                            @if (isAdmin)
                            {
                                <form asp-action="DeleteAttachment" asp-route-id="@a.Id" method="post"
                                      onsubmit="return confirm(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Invoice.Details.DeleteAttachmentConfirm"].Value)));"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm py-0">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="card-body py-2">
                    <p class="text-muted mb-0 small">@L["Invoice.Details.NoAttachments"]</p>
                </div>
            }

            @if (isAdmin)
            {
                <div class="card-footer p-2">
                    <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="invoiceId" value="@Model.Id" />
                        <div class="input-group input-group-sm">
                            <input type="file" name="file" class="form-control form-control-sm" required />
                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-upload me-1"></i>@L["Common.Upload"]
                            </button>
                        </div>
                        <small class="text-muted">Max 20 MB</small>
                    </form>
                </div>
            }
        </div>

    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-bar-chart me-2"></i>@L["Invoice.Details.Summary"]</div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted small">@L["Invoice.Create.Subtotal"]</span>
                    <span class="fw-semibold small">@Model.SubTotal.ToString("C")</span>
                </div>
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted small">@L["Invoice.Create.Vat"]</span>
                    <span class="fw-semibold small">@Model.VatAmount.ToString("C")</span>
                </div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold">@L["Invoice.Details.Payable"]</span>
                    <span class="fw-bold text-primary fs-5">@Model.TotalAmount.ToString("C")</span>
                </div>
            </div>
        </div>

        @if (isAdmin && statusModel is not null)
        {
            <div class="card border-warning">
                <div class="card-header bg-warning bg-opacity-25">
                    <i class="bi bi-sliders me-2"></i>@L["Invoice.Details.Manage"]
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" asp-for="@statusModel.Id" name="Id" />

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">@L["Dash.Col.Status"]</label>
                            <select name="Status" id="invoice-status-admin" class="form-select form-select-sm"
                                    onchange="togglePaidDate(this.value)">
                                @foreach (var s in Enum.GetValues<InvoiceStatus>())
                                {
                                    <option value="@s" selected="@(statusModel.Status == s)">@StatusLabel(s)</option>
                                }
                            </select>
                        </div>

                        <div id="paid-date-row" class="mb-3"
                             style="display:@(statusModel.Status == InvoiceStatus.Paid ? "block" : "none")">
                            <label class="form-label small fw-semibold">@L["Invoice.Details.PaidDate"]</label>
                            <input type="date" name="PaidAt" id="invoice-paid-at"
                                   class="form-control form-control-sm"
                                   value="@(statusModel.PaidAt?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" id="btn-invoice-save" class="btn btn-warning btn-sm fw-semibold">
                                <i class="bi bi-check-lg me-1"></i>@L["Common.Save"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }

        @if (history.Any())
        {
            <div class="card mt-3">
                <div class="card-header bg-surface2">
                    <i class="bi bi-clock-history me-2"></i>@L["Invoice.Details.CustomerHistory"]
                </div>
                <div class="card-body p-0">
                    <ul class="invoice-list">
                        @foreach (var inv in history)
                        {
                            var hCss = HistoryCss(inv.Status);

                            <li>
                                <div class="inv-left">
                                    <span class="inv-num">
                                        <a asp-action="Details" asp-route-id="@inv.Id" class="link-subtle">
                                            @inv.InvoiceNumber
                                        </a>
                                    </span>
                                    <span class="inv-customer">@inv.InvoiceDate.ToString("dd.MM.yyyy")</span>
                                </div>
                                <div class="inv-right d-flex align-items-center gap-2">
                                    <span class="inv-amount">@inv.TotalAmount.ToString("N2") €</span>
                                    <i class="bi bi-circle-fill @hCss" style="font-size: 0.5rem;" title="@StatusLabel(inv.Status)"></i>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function togglePaidDate(status) {
    document.getElementById('paid-date-row').style.display =
        status === 'Paid' ? 'block' : 'none';
}
</script>
}
