@model IEnumerable<HakaTech.Portal.Models.Domain.Invoice>
@using HakaTech.Portal.Models.Domain
@{
    ViewData["Title"] = L["Invoice.Index.Title"].Value;
    bool isAdmin        = (bool)(ViewBag.IsAdmin ?? false);
    var statusFilter    = ViewBag.StatusFilter as InvoiceStatus?;
    int? customerFilter = ViewBag.CustomerFilter;

    string StatusLabel(InvoiceStatus s) => L[$"InvoiceStatus.{s}"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-receipt me-2"></i>@L["Invoice.Index.Title"]</h2>
    @if (isAdmin)
    {
        <a asp-action="Create" id="btn-invoice-create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>@L["Invoice.Index.New"]
        </a>
    }
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3 align-items-end">
    @if (customerFilter.HasValue)
    {
        <input type="hidden" name="customerId" value="@customerFilter" />
    }
    <div class="col-md-3">
        <select name="status" id="invoice-status-filter" class="form-select">
            <option value="">@L["Ticket.Index.AllStatuses"]</option>
            @foreach (var s in Enum.GetValues<InvoiceStatus>())
            {
                <option value="@s" selected="@(statusFilter == s)">@StatusLabel(s)</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">
            <i class="bi bi-funnel"></i> @L["Common.Filter"]
        </button>
        <a asp-action="Index" class="btn btn-outline-danger ms-1" title="@L["Common.ClearFilter"]">
            <i class="bi bi-x-lg"></i>
        </a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-receipt text-muted" style="font-size:3rem"></i>
            <p class="mt-3 mb-1 fw-semibold text-muted">@L["Invoice.Index.Empty.Title"]</p>
            <p class="text-muted small mb-0">@L["Invoice.Index.Empty.Sub"]</p>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>@L["Invoice.Col.Number"]</th>
                    @if (isAdmin) { <th>@L["Dash.Col.Customer"]</th> }
                    <th>@L["Invoice.Col.Date"]</th>
                    <th>@L["Invoice.Col.DueDate"]</th>
                    <th class="text-end">@L["Invoice.Col.Total"]</th>
                    <th>@L["Dash.Col.Status"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in Model)
                {
                    string badgeCss = inv.Status switch {
                        InvoiceStatus.Paid    => "bg-success",
                        InvoiceStatus.Overdue => "bg-danger",
                        InvoiceStatus.Sent    => "bg-primary",
                        InvoiceStatus.Unpaid  => "bg-warning text-dark",
                        _                     => "bg-secondary"
                    };
                    <tr class="@(inv.Status == InvoiceStatus.Overdue ? "table-danger" : "")">
                        <td>
                            <a asp-action="Details" asp-route-id="@inv.Id"
                               class="fw-semibold text-decoration-none">
                                @inv.InvoiceNumber
                            </a>
                        </td>
                        @if (isAdmin)
                        {
                            <td class="small text-muted">@(inv.Customer?.CompanyName ?? "—")</td>
                        }
                        <td class="small">@inv.InvoiceDate.ToString("dd.MM.yyyy")</td>
                        <td class="small @(inv.DueDate < DateTime.Today && inv.Status != InvoiceStatus.Paid ? "text-danger fw-semibold" : "")">
                            @inv.DueDate.ToString("dd.MM.yyyy")
                        </td>
                        <td class="text-end fw-semibold">@inv.TotalAmount.ToString("C")</td>
                        <td><span class="badge @badgeCss">@StatusLabel(inv.Status)</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@inv.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-semibold">
                <tr>
                    <td colspan="@(isAdmin ? 4 : 3)">@string.Format(L["Invoice.TotalRow"].Value, Model.Count())</td>
                    <td class="text-end">@Model.Sum(i => i.TotalAmount).ToString("C")</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>
}
