@model HakaTech.Portal.Models.ViewModels.KbArticleDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Tietopankki</a></li>
        <li class="breadcrumb-item">
            <a asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a>
        </li>
        <li class="breadcrumb-item active text-truncate" style="max-width:300px">@Model.Title</li>
    </ol>
</nav>

<div class="row g-4">

    @* ── Artikkelin sisältö ──────────────────────────────────────── *@
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-md-5">

                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-light text-secondary border">@Model.CategoryName</span>
                    <span class="text-muted small">
                        <i class="bi bi-eye me-1"></i>@Model.ViewCount lukemista
                    </span>
                    <span class="text-muted small">
                        <i class="bi bi-clock me-1"></i>Päivitetty @Model.UpdatedAt.ToString("d.M.yyyy")
                    </span>
                </div>

                <h1 class="h3 fw-bold mb-4">@Model.Title</h1>

                <div class="kb-content">
                    @Html.Raw(Model.Content)
                </div>

                <hr class="my-4" />
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                        Kirjoittanut @Model.Author · @Model.CreatedAt.ToString("d.M.yyyy")
                    </div>
                    <div class="d-flex gap-2">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="EditArticle" asp-route-id="@Model.Id"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-pencil me-1"></i>Muokkaa
                            </a>
                        }
                        <a asp-controller="Ticket" asp-action="Create"
                           class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-ticket-perforated me-1"></i>Luo tiketti silti
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Sivupalkki: muut artikkelit ────────────────────────────── *@
    <div class="col-lg-4">
        @if (Model.RelatedArticles.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-0 pb-0 pt-3 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-collection me-2 text-primary"></i>Muut ohjeet samassa kategoriassa
                    </h6>
                </div>
                <div class="list-group list-group-flush px-2 pb-2">
                    @foreach (var a in Model.RelatedArticles)
                    {
                        <a asp-action="Article" asp-route-id="@a.Id"
                           class="list-group-item list-group-item-action border-0 py-2 px-3 rounded">
                            <div class="small fw-medium">@a.Title</div>
                            <div class="text-muted" style="font-size:.75rem">
                                <i class="bi bi-eye me-1"></i>@a.ViewCount
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body p-4 text-center">
                <i class="bi bi-headset display-6 mb-2"></i>
                <h6 class="fw-bold">Eikö ohje auttanut?</h6>
                <p class="small mb-3 opacity-75">Tukitiimimme auttaa arkisin 8–17.</p>
                <a asp-controller="Ticket" asp-action="Create"
                   class="btn btn-light btn-sm fw-semibold">
                    <i class="bi bi-ticket-perforated me-1"></i>Luo tukitiketti
                </a>
            </div>
        </div>
    </div>

</div>

<style>
    .kb-content h2 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; }
    .kb-content h3 { font-size: 1.05rem; font-weight: 600; margin-top: 1.25rem; }
    .kb-content p  { line-height: 1.75; }
    .kb-content ul, .kb-content ol { padding-left: 1.5rem; }
    .kb-content li { margin-bottom: .35rem; line-height: 1.7; }
    .kb-content table { font-size: .9rem; }
</style>
