@model HakaTech.Portal.Models.ViewModels.KbCategoryFormViewModel
@{
    bool   isNew  = Model.Id == 0;
    string action = isNew ? "CreateCategory" : "EditCategory";
    ViewData["Title"] = (isNew ? L["KB.CategoryNew"] : L["KB.CategoryEdit"]).Value;
}

<div class="mb-3">
    <a asp-action="Categories" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Takaisin kategorioihin
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header @(isNew ? "bg-primary" : "bg-secondary") text-white py-3">
                <h5 class="mb-0">
                    <i class="bi bi-tag me-2"></i>@ViewData["Title"]
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="@action" asp-route-id="@(isNew ? null : Model.Id.ToString())" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="display:none"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium"></label>
                        <input asp-for="Name" class="form-control" placeholder="esim. Tekniset ohjeet" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-medium"></label>
                        <input asp-for="Description" class="form-control" placeholder="Lyhyt kuvaus (valinnainen)" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SortOrder" class="form-label fw-medium"></label>
                        <input asp-for="SortOrder" class="form-control" type="number" min="0" style="max-width: 100px" />
                        <div class="form-text">Pienempi numero näytetään ensin.</div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Aktiivinen</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>Tallenna
                        </button>
                        <a asp-action="Categories" class="btn btn-outline-secondary">Peruuta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
