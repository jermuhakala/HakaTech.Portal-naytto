@*
    KnowledgeBase/Index.cshtml — Tietopankin etusivu.

    Rakenne:
      - Otsikkorivi: admin saa "Hallinta" ja "Uusi artikkeli" -painikkeet
      - Hakupalkki: GET-lomake, parametri q (query)
      - Kategoriapainikkeet: suodattavat artikkeleita categoryId-parametrilla
      - Featured-artikkelit: nostetut (IsFeatured=true) korttiruudukossa
      - Artikkelilista: hakutulokset tai kaikki artikkelit (list-group)

    Yhteys: KnowledgeBaseController.Index.
*@

@* KbIndexViewModel sisältää: SearchQuery, CategoryId, Categories,
   Featured (nostetut artikkelit), Articles (hakutulokset tai kaikki). *@
@model HakaTech.Portal.Models.ViewModels.KbIndexViewModel

@{
    ViewData["Title"] = L["KB.Index.Title"].Value;
}

@* Otsikkorivi: vasemmalla nimi + aliotsikko, oikealla adminipainikkeet. *@
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        @* bi-book = kirja-ikoni. *@
        <h2 class="fw-bold mb-1"><i class="bi bi-book me-2 text-primary"></i>@L["KB.Index.Title"]</h2>
        @* Lyhyt esittely tietopankista. *@
        <p class="text-muted mb-0">@L["KB.Index.Intro"]</p>
    </div>
    @* Admin-painikkeet: hallinta ja uuden artikkelin luonti.
       User.IsInRole("Admin") = tarkistaa kirjautuneen käyttäjän roolin. *@
    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex gap-2">
            <a asp-action="Manage" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-gear me-1"></i>@L["KB.Manage"]
            </a>
            <a asp-action="CreateArticle" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>@L["KB.NewArticle"]
            </a>
        </div>
    }
</div>

@* Hakupalkki-kortti, jossa liukuvärinen tausta.
   linear-gradient(135deg, #0d6efd15, #6610f215) = sinisestä purppuraan 15 % läpikuultavana.
   method="get" = hakusana menee URL-parametriksi (?q=...). *@
<div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #0d6efd15 0%, #6610f215 100%);">
    <div class="card-body p-4">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            @* type="search" = semanttisesti hakukenttä (selain voi lisätä X-tyhjennysnapin).
               value="@Model.SearchQuery" = esitäyttää edellisen haun (ei häviä sivulatauksen jälkeen). *@
            <input type="search" name="q" value="@Model.SearchQuery"
                   class="form-control form-control-lg"
                   placeholder="@L["KB.SearchBigPlaceholder"]" />
            @* px-4 = lisätty vaakapadding painikkeelle (leveä painike). *@
            <button type="submit" class="btn btn-primary btn-lg px-4">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>
</div>

@* Kategoriapainikkeet vaakasuorassa rivissä. flex-wrap = rivityy pienellä näytöllä.
   Jokainen on linkki saman Index-sivun eri categoryId-parametrilla.
   SearchQuery säilyy kaikkien kategorialinkkien yli (asp-route-q). *@
<div class="d-flex flex-wrap gap-2 mb-4">
    @* "Kaikki" = ei categoryId-parametria.
       btn-primary = korostettu jos ei kategoriaa valittuna (Model.CategoryId is null). *@
    <a asp-action="Index" asp-route-q="@Model.SearchQuery"
       class="btn btn-sm @(Model.CategoryId is null ? "btn-primary" : "btn-outline-secondary")">
        @L["Common.All"]
    </a>
    @* Jokainen kategoria omana painikkeenaan. *@
    @foreach (var cat in Model.Categories)
    {
        @* Aktiivinen kategoria = btn-primary, muut = btn-outline-secondary. *@
        <a asp-action="Index" asp-route-q="@Model.SearchQuery" asp-route-categoryId="@cat.Id"
           class="btn btn-sm @(Model.CategoryId == cat.Id ? "btn-primary" : "btn-outline-secondary")">
            @cat.Name
        </a>
    }
</div>

@* Nostetut artikkelit (Featured) näytetään vain jos niitä on. *@
@if (Model.Featured.Count > 0)
{
    @* bi-star-fill text-warning = täytetty tähti keltaisena. *@
    <h5 class="fw-semibold mb-3"><i class="bi bi-star-fill text-warning me-2"></i>@L["KB.Popular"]</h5>
    @* Korttiruudukko: kaksi saraketta leveillä näytöillä (col-md-6).
       g-3 = 16px väli. mb-5 = isompi alamarginaali ennen listaa. *@
    <div class="row g-3 mb-5">
        @foreach (var a in Model.Featured)
        {
            <div class="col-md-6">
                @* Koko kortti on linkki — text-decoration-none, text-dark estää linkkityylit.
                   hover-card = CSS:ssä määritelty transform-animaatio hoverrilla. *@
                <a asp-action="Article" asp-route-id="@a.Id"
                   class="card h-100 border-0 shadow-sm text-decoration-none text-dark hover-card">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-start gap-2">
                            @* bi-file-earmark-text = dokumentti-ikoni.
                               fs-4 = iso (1.5rem). flex-shrink-0 = ei kutiste. *@
                            <i class="bi bi-file-earmark-text fs-4 text-primary mt-1 flex-shrink-0"></i>
                            <div>
                                @* Artikkelin otsikko. *@
                                <div class="fw-semibold">@a.Title</div>
                                @* Excerpt = lyhennelmä artikkelin ensimmäisistä lauseista. *@
                                <div class="text-muted small mt-1">@a.Excerpt</div>
                                <div class="mt-2">
                                    @* Kategorian nimi badgena. *@
                                    <span class="badge bg-light text-secondary border">@a.CategoryName</span>
                                    @* Lukemiskerrat. bi-eye = silmä-ikoni. *@
                                    <span class="text-muted small ms-2">
                                        <i class="bi bi-eye me-1"></i>@a.ViewCount
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

@* Listan otsikko vaihtelee tilanteen mukaan. *@
@if (!string.IsNullOrWhiteSpace(Model.SearchQuery) || Model.CategoryId.HasValue)
{
    @* Hakutulos- tai kategoriaotsikko. *@
    <h5 class="fw-semibold mb-3">
        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            @* Esim: "Hakutulokset: verkko (3)". <em> = kursiivi hakusanalle. *@
            <span>@L["KB.SearchResults"]: <em>@Model.SearchQuery</em> (@Model.Articles.Count)</span>
        }
        else
        {
            @* Kategoriaotsikko: haetaan nimi categorien listasta.
               FirstOrDefault(c => c.Id == Model.CategoryId)?.Name ?? ""
               = etsitään kategoria ID:llä, otetaan nimi, tai tyhjä jos ei löydy. *@
            <span>@(Model.Categories.FirstOrDefault(c => c.Id == Model.CategoryId)?.Name ?? "") (@Model.Articles.Count)</span>
        }
    </h5>
}
else if (Model.Featured.Count == 0)
{
    @* Ei nostettuja artikkeleita — kaikki artikkelit yhtenä listana. *@
    <h5 class="fw-semibold mb-3">@L["KB.AllArticles"]</h5>
}
else
{
    @* Nostettujen alla: muut artikkelit. *@
    <h5 class="fw-semibold mb-3">@L["KB.OtherArticles"]</h5>
}

@* Artikkelilista. *@
@if (Model.Articles.Count == 0)
{
    @* Ei tuloksia. *@
    <div class="text-center text-muted py-5">
        <i class="bi bi-search display-4 d-block mb-3"></i>
        @* Hakusana näkyy lainausmerkeissä. *@
        <p>@L["KB.NoResults"] "<strong>@Model.SearchQuery</strong>".</p>
        @* Ohjauspainike kaikkien näyttämiseen (nollaa hakusuodatin). *@
        <a asp-action="Index" class="btn btn-outline-primary btn-sm mt-1">@L["KB.ShowAll"]</a>
    </div>
}
else
{
    @* list-group-flush = lista ilman ulkoreunoja (sopii kortilla).
       rounded shadow-sm = korttimainen ilme. *@
    <div class="list-group list-group-flush shadow-sm rounded">
        @foreach (var a in Model.Articles)
        {
            @* Koko rivi on linkki. list-group-item-action = hover-efekti Bootstrap-listariville. *@
            <a asp-action="Article" asp-route-id="@a.Id"
               class="list-group-item list-group-item-action py-3 px-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="d-flex align-items-center gap-2">
                            @* Tähti nostettujen artikkeleille. *@
                            @if (a.IsFeatured)
                            {
                                <i class="bi bi-star-fill text-warning small"></i>
                            }
                            @* Artikkelin otsikko. *@
                            <span class="fw-semibold">@a.Title</span>
                        </div>
                        @* Lyhennelmä. *@
                        <div class="text-muted small mt-1">@a.Excerpt</div>
                    </div>
                    @* Oikealla: kategoria + lukemiskerrat.
                       flex-shrink-0 ms-3 = ei kutiste, vasen marginaali. *@
                    <div class="text-end flex-shrink-0 ms-3">
                        <span class="badge bg-light text-secondary border small">@a.CategoryName</span>
                        <div class="text-muted small mt-1">
                            <i class="bi bi-eye me-1"></i>@a.ViewCount
                        </div>
                    </div>
                </div>
            </a>
        }
    </div>
}

@* Inline-CSS hover-efektille featured-korteille.
   transform: translateY(-2px) = nostetaan 2px ylös hoverrilla (kohoefekti).
   transition = animaatioaika 0.15s pehmentää siirtymän. *@
<style>
    .hover-card { transition: transform .15s, box-shadow .15s; }
    .hover-card:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.12) !important; }
</style>
