@{
    string? guacUrl        = ViewBag.GuacamoleUrl as string;
    string  connectionName = ViewBag.ConnectionName as string ?? "Etätyöpöytä";
    Layout = guacUrl is not null ? null : "_Layout";
    ViewData["Title"] = connectionName;
}

@if (guacUrl is not null)
{
    <!DOCTYPE html>
    <html lang="fi">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@connectionName – Etätyöpöytä</title>
        <style>
            *, html, body { margin: 0; padding: 0; box-sizing: border-box; }
            body { background: #000; }
            iframe { display: block; width: 100vw; height: 100vh; border: none; }
        </style>
    </head>
    <body>
        <iframe src="@guacUrl" allowfullscreen allow="clipboard-read; clipboard-write"></iframe>
    </body>
    </html>
}
else
{
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Takaisin
        </a>
    </div>

    <div class="row justify-content-center mt-4">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-display display-3 text-muted mb-3"></i>
                    <h4 class="fw-bold">Etätyöpöytäpalvelu ei ole käytössä</h4>
                    <p class="text-muted mt-2 mb-4">
                        Guacamole-yhteyden asetukset (<code>GuacamoleSettings:BaseUrl</code>) puuttuvat
                        palvelimen konfiguraatiosta. Ota yhteyttä ylläpitoon.
                    </p>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Takaisin yhteyksiin
                    </a>
                </div>
            </div>
        </div>
    </div>
}
