@*
    RemoteDesktop/Connect.cshtml — Etätyöpöytäyhteyden avaussivu.
    Renderöi Guacamole-iframen, jossa varsinainen RDP/VNC/SSH-istunto
    pyörii. URL on kertakäyttöinen — tokenin elinikä on rajoitettu.
*@
@{
    string? guacUrl        = ViewBag.GuacamoleUrl as string;
    string  connectionName = ViewBag.ConnectionName as string ?? "Etätyöpöytä";
    Layout = "_Layout";
    ViewData["Title"] = connectionName;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Takaisin yhteyksiin
    </a>
</div>

@if (guacUrl is not null)
{
    <div class="row justify-content-center mt-2">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-display-fill display-3 text-primary mb-3"></i>
                    <h4 class="fw-bold">@connectionName</h4>
                    <p class="text-muted mt-2 mb-4">
                        Etätyöpöytäyhteys avataan uuteen selainvälilehteen.<br />
                        Jos välilehti ei aukea, salli ponnahdusikkunat selaimessa.
                    </p>
                    <a href="@guacUrl" target="_blank" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-up-right me-2"></i>Avaa etätyöpöytä
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Avaa automaattisesti heti sivun latautuessa
        window.open('@guacUrl', '_blank');
    </script>
}
else
{
    <div class="row justify-content-center mt-4">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-display display-3 text-muted mb-3"></i>
                    <h4 class="fw-bold">Etätyöpöytäpalvelu ei ole käytössä</h4>
                    <p class="text-muted mt-2 mb-4">
                        Guacamole-yhteyden asetukset puuttuvat palvelimen konfiguraatiosta.
                        Ota yhteyttä ylläpitoon.
                    </p>
                </div>
            </div>
        </div>
    </div>
}
