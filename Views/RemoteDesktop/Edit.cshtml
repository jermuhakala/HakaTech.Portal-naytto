@model HakaTech.Portal.Models.ViewModels.RemoteDesktopConnectionFormViewModel
@using HakaTech.Portal.Models.Domain
@{
    ViewData["Title"] = "Muokkaa etäyhteyttä";
}

<div class="mb-3">
    <a asp-action="Manage" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Takaisin hallintaan
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Muokkaa etäyhteyttä</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="display:none"></div>

                    @* Asiakas *@
                    <div class="mb-3">
                        <label asp-for="CustomerId" class="form-label fw-medium"></label>
                        <select asp-for="CustomerId" asp-items="Model.CustomerOptions" class="form-select">
                            <option value="">– Valitse asiakas –</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger small"></span>
                    </div>

                    @* Nimi *@
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    @* Protokolla + portti *@
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Protocol" class="form-label fw-medium"></label>
                            <select asp-for="Protocol"
                                    asp-items="Html.GetEnumSelectList<RemoteDesktopProtocol>()"
                                    class="form-select"
                                    id="protocolSelect">
                            </select>
                            <span asp-validation-for="Protocol" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Port" class="form-label fw-medium"></label>
                            <input asp-for="Port" class="form-control" type="number" min="1" max="65535" />
                            <span asp-validation-for="Port" class="text-danger small"></span>
                        </div>
                    </div>

                    @* Isäntänimi *@
                    <div class="mb-3">
                        <label asp-for="Hostname" class="form-label fw-medium"></label>
                        <input asp-for="Hostname" class="form-control" />
                        <span asp-validation-for="Hostname" class="text-danger small"></span>
                    </div>

                    @* Käyttäjätunnus + salasana *@
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label fw-medium"></label>
                            <input asp-for="Username" class="form-control" autocomplete="off" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PlainPassword" class="form-label fw-medium"></label>
                            <input asp-for="PlainPassword" class="form-control" type="password"
                                   autocomplete="new-password"
                                   placeholder="Jätä tyhjäksi pitääksesi nykyisen" />
                            <span asp-validation-for="PlainPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    @* RDP-asetukset *@
                    <div id="rdpSettings" class="mb-3">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Security" class="form-label fw-medium"></label>
                                <select asp-for="Security" class="form-select">
                                    <option value="any">any (automaattinen)</option>
                                    <option value="rdp">rdp</option>
                                    <option value="nla">nla (NLA)</option>
                                    <option value="tls">tls (TLS)</option>
                                </select>
                            </div>
                            <div class="col-md-6 d-flex align-items-end pb-1">
                                <div class="form-check">
                                    <input asp-for="IgnoreCert" class="form-check-input" type="checkbox" />
                                    <label asp-for="IgnoreCert" class="form-check-label">@Html.DisplayNameFor(m => m.IgnoreCert)</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Muistiinpanot *@
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-medium"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    @* Aktiivinen *@
                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Aktiivinen (näkyy asiakkaalle)</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>Tallenna muutokset
                        </button>
                        <a asp-action="Manage" class="btn btn-outline-secondary">Peruuta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const proto  = document.getElementById('protocolSelect');
        const rdpDiv = document.getElementById('rdpSettings');

        function toggleRdp() {
            rdpDiv.style.display = proto.value === '0' ? '' : 'none';
        }

        proto.addEventListener('change', toggleRdp);
        toggleRdp();
    </script>
}
