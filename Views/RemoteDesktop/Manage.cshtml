@*
    RemoteDesktop/Manage.cshtml — Adminin hallintasivu kaikille etäyhteyksille.

    Listaa kaikki yhteydet (kaikki asiakkaat) taulukossa.
    Admin voi:
      - Yhdistä (Testaa yhteyden toimivuuden selaimessa)
      - Muokkaa (Edit)
      - Poista käytöstä (Delete = pehmytpoisto, asettaa IsActive=false)

    Pehmytpoisto: poistetut yhteydet näytetään himmennettyinä (table-secondary),
    niissä ei ole "Yhdistä"- eikä "Poista"-painiketta.

    Yhteys: RemoteDesktopController.Manage.
*@

@* Malli = kaikki RemoteDesktopConnection-entiteetit (Customer-navigaatio ladattu). *@
@model IEnumerable<HakaTech.Portal.Models.Domain.RemoteDesktopConnection>
@using HakaTech.Portal.Models.Domain

@{
    ViewData["Title"] = L["RemoteDesktop.ManageTitle"].Value;
}

@* Otsikkorivi + "Lisää yhteys" -painike. *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-display me-2"></i>Etätyöpöytä – Hallinta</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Lisää yhteys
    </a>
</div>

@* Tyhjä tila. *@
@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i>Ei etäyhteyksiä. Lisää ensimmäinen yhteys yllä olevasta painikkeesta.
    </div>
}
else
{
    @* Yhteydet taulukossa kortissa. *@
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Asiakas</th>
                        <th>Nimi</th>
                        <th>Protokolla</th>
                        <th>Isäntänimi</th>
                        <th class="text-center">Portti</th>
                        <th class="text-center">Tila</th>
                        <th class="text-end">Toiminnot</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        @* protoColor = Bootstrap-värinimi protokollan mukaan. *@
                        var protoColor = c.Protocol switch {
                            RemoteDesktopProtocol.Rdp => "primary",
                            RemoteDesktopProtocol.Vnc => "warning",
                            RemoteDesktopProtocol.Ssh => "success",
                            _                         => "secondary"
                        };

                        @* Inaktiivinen yhteys: harmaa ja himmennettynä (table-secondary text-muted). *@
                        <tr class="@(!c.IsActive ? "table-secondary text-muted" : "")">
                            @* Asiakkaan yritysnimi. *@
                            <td class="small fw-semibold">@(c.Customer?.CompanyName ?? "-")</td>
                            @* Yhteyden nimi. *@
                            <td class="fw-semibold">@c.Name</td>
                            @* Protokolla-badge.
                               -subtle = Bootstrap 5.3: vaalea väritausta.
                               -emphasis = korostunut tekstiväri (enemmän kontrasti kuin -fg). *@
                            <td>
                                <span class="badge bg-@(protoColor)-subtle text-@(protoColor)-emphasis fw-semibold">
                                    @* ToUpper() = "RDP", "VNC", "SSH" isoilla kirjaimilla. *@
                                    @c.Protocol.ToString().ToUpper()
                                </span>
                            </td>
                            @* Isäntänimi. font-monospace = koodifontti IP/FQDN-osoitteille.
                               text-truncate max-width = katkaisee liian pitkät osoitteet. *@
                            <td class="small font-monospace text-truncate" style="max-width:220px">@c.Hostname</td>
                            <td class="text-center small">@c.Port</td>
                            @* Tila: Aktiivinen / Poistettu käytöstä. *@
                            <td class="text-center">
                                @if (c.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis">Aktiivinen</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis">Poistettu</span>
                                }
                            </td>
                            @* Toiminnot oikealle. text-nowrap = ei rivitystä. *@
                            <td class="text-end text-nowrap">
                                @* Yhdistä-painike vain aktiivisille yhteyksille. *@
                                @if (c.IsActive)
                                {
                                    @* btn-outline-@protoColor = värikoodi protokollan mukaan.
                                       target="_blank" rel="noopener noreferrer" = turvallisuus. *@
                                    <a asp-action="Connect" asp-route-id="@c.Id"
                                       class="btn btn-sm btn-outline-@protoColor me-1"
                                       target="_blank" rel="noopener noreferrer"
                                       title="Yhdistä">
                                        <i class="bi bi-plug"></i>
                                    </a>
                                }
                                @* Muokkaa — aina näkyvissä myös inaktiivisille. *@
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-secondary me-1"
                                   title="Muokkaa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @* Poista käytöstä — vain aktiivisille. *@
                                @if (c.IsActive)
                                {
                                    @* RZ1031-korjaus: Razor tag helper (<form asp-*>) ei salli C#-lausekkeita
                                       tavallisissa HTML-attribuuteissa (kuten onsubmit). Ratkaisu: siirretään
                                       confirm-kutsu painikkeen onclick-attribuuttiin, jossa C# on sallittu
                                       koska <button> ei ole tag helper (ei asp-* attribuutteja).
                                       “ ja ” = Unicode-koodipisteet vasemmalle ja oikealle
                                       lainausmerkille — turvallinen tapa JS-merkkijonoissa. *@
                                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Poista käytöstä"
                                                onclick="return confirm('Poistetaanko yhteys “@(c.Name)” käytöstä?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
