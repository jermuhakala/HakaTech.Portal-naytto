@*
    Report/Index.cshtml — Raporttisivu (vain admin).

    Sisältö:
      1. Aikavälisuodattimet (weeksBack, monthsBack) GET-lomakkeessa
         → onchange="this.form.submit()" = lähettää lomakkeen välittömästi valintaa vaihtaessa
      2. Tikettitilastot viikoittain — Chart.js palkkikaavio (luotu vs. ratkaistu)
      3. Tiketin tila-jakauma — Chart.js donut-kaavio (avoin, käsittelyssä, odottaa, ratkaistu, suljettu)
      4. Palautekeskiarvo — tähtiikoni täyttöasteella + arvioiden määrä
      5. Laskutustiivistelmä — kolme summaa (laskutettu / maksettu / avoin)
      6. Laskutuskaavio kuukausittain — toinen Chart.js palkkikaavio
      7. Laskutustaulukko kuukausittain — tfoot:ssa yhteensä-rivi

    Vienti:
      - ExportTicketsCsv → CSV-tiedosto tiketistä
      - ExportBillingCsv → CSV-tiedosto laskutuksesta
      - ExportBillingPdf → PDF-raportti (asp-route-monthsBack säilyttää aikavälin)

    Yhteys: ReportController.Index.
*@

@* ReportIndexViewModel sisältää:
   WeeksBack, MonthsBack, WeeklyStats, MonthlyStats,
   CountOpen/InProgress/WaitingCustomer/Resolved/Closed,
   AvgFeedbackRating?, FeedbackCount,
   TotalBilledExcl, TotalBilledIncl, TotalPaid. *@
@model HakaTech.Portal.Models.ViewModels.ReportIndexViewModel

@* Tuodaan JsonSerializer C#-puolella datan serialisointia varten. *@
@using System.Text.Json

@{
    ViewData["Title"] = L["Report.Index.Title"].Value;

    @* Muunnetaan Chart.js -kaavioihin tarvittavat taulukot JSON-muotoon.
       Select() = LINQ-projektio: otetaan vain tarvittu kenttä mallioliosta.
       JsonSerializer.Serialize() = turvallinen tapa tuottaa JS-taulukko Razor:sta.
       Html.Raw() estää < > & -merkkien HTML-enkoodauksen JSON:ssa. *@

    @* Tikettitilastojen akseli-etiketit (viikkonumerot tai päivämäärät). *@
    var chartLabels   = JsonSerializer.Serialize(Model.WeeklyStats.Select(s => s.Label));
    @* Luotujen tikettien lukumäärä jokaiselle viikolle. *@
    var chartCreated  = JsonSerializer.Serialize(Model.WeeklyStats.Select(s => s.Created));
    @* Ratkaistujen/suljettujen tikettien lukumäärä jokaiselle viikolle. *@
    var chartResolved = JsonSerializer.Serialize(Model.WeeklyStats.Select(s => s.Resolved));

    @* Laskutuskaavion akseli-etiketit (kuukausinimet, esim. "Toukokuu 2025"). *@
    var billingLabels  = JsonSerializer.Serialize(Model.MonthlyStats.Select(s => s.Label));
    @* Kuukausittaiset laskutussummat (sis. ALV). (double) = muunnetaan decimal→double Chart.js:lle. *@
    var billingTotals  = JsonSerializer.Serialize(Model.MonthlyStats.Select(s => (double)s.TotalIncl));
    @* Kuukausittaiset maksetut summat. *@
    var billingPaid    = JsonSerializer.Serialize(Model.MonthlyStats.Select(s => (double)s.PaidAmount));
}

@* Otsikkorivi + vientinapit.
   flex-wrap gap-2 = rivityy mobiililla. *@
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h2 class="mb-0"><i class="bi bi-bar-chart-line me-2"></i>Raportit</h2>
    <div class="d-flex gap-2">
        @* CSV-vienti tiketeistä. *@
        <a asp-action="ExportTicketsCsv" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-filetype-csv me-1"></i>Tiketit CSV
        </a>
        @* CSV-vienti laskutuksesta. *@
        <a asp-action="ExportBillingCsv" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-filetype-csv me-1"></i>Laskutus CSV
        </a>
        @* PDF-vienti laskutuksesta. asp-route-monthsBack = aikaväli säilyy URL-parametrina. *@
        <a asp-action="ExportBillingPdf" asp-route-monthsBack="@Model.MonthsBack"
           class="btn btn-outline-danger btn-sm">
            <i class="bi bi-file-earmark-pdf me-1"></i>Laskutus PDF
        </a>
    </div>
</div>

@* Aikavälisuodattimet.
   method="get" = parametrit URL:iin (weeksBack ja monthsBack).
   onchange="this.form.submit()" = lomake lähetetään välittömästi valintaa vaihdettaessa
   — ei tarvita erillistä "Hae"-painiketta. *@
<form method="get" class="card card-body mb-4 py-2">
    <div class="row g-2 align-items-end">
        @* Tikettitilastojen aikaväli. *@
        <div class="col-sm-auto">
            <label class="form-label small fw-semibold mb-1">Tikettitilastot (viikkoja)</label>
            <select name="weeksBack" class="form-select form-select-sm" onchange="this.form.submit()">
                @* Vaihtoehtojen taulukko: 4, 8, 12, 24, 52 viikkoa. *@
                @foreach (var w in new[] { 4, 8, 12, 24, 52 })
                {
                    @* Vertaa nykyiseen arvoon: jos sama, lisätään "selected"-attribuutti.
                       Huom: tässä if/else without @:  — Razor ei vaadi @: jos ei ole tekstitulostusta. *@
                    if (Model.WeeksBack == w)
                    { <option value="@w" selected>Viimeiset @w viikkoa</option> }
                    else
                    { <option value="@w">Viimeiset @w viikkoa</option> }
                }
            </select>
        </div>
        @* Laskutusyhteenvedon aikaväli. *@
        <div class="col-sm-auto">
            <label class="form-label small fw-semibold mb-1">Laskutusyhteenveto (kuukausia)</label>
            <select name="monthsBack" class="form-select form-select-sm" onchange="this.form.submit()">
                @foreach (var m in new[] { 3, 6, 12, 24 })
                {
                    if (Model.MonthsBack == m)
                    { <option value="@m" selected>Viimeiset @m kuukautta</option> }
                    else
                    { <option value="@m">Viimeiset @m kuukautta</option> }
                }
            </select>
        </div>
    </div>
</form>

<div class="row g-4 mb-4">

    @* ── Tikettitilastot (palkkikaavio) ── *@
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-ticket-detailed me-2"></i>Tikettitilastot – viikottain</span>
                @* CSV-latauslinkki suoraan korttinotsikossa. *@
                <a asp-action="ExportTicketsCsv" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-download me-1"></i>CSV
                </a>
            </div>
            <div class="card-body">
                @* <canvas> = Chart.js piirtää kaavion tähän elementtiin.
                   max-height estää kaavion kasvamasta liian suureksi. *@
                <canvas id="ticketChart" style="max-height:280px;"></canvas>
            </div>
        </div>
    </div>

    @* ── Tila-jakauma (donut-kaavio) ── *@
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-pie-chart me-2"></i>Tiketin tila-jakauma (kaikki)</div>
            @* d-flex align-items-center = kaavio ja selite vierekkäin. flex-wrap = mobiililla pino. *@
            <div class="card-body d-flex align-items-center gap-4 flex-wrap">
                @* Donut-kaavio. max-width:200px = pyöreä eikä veny. *@
                <canvas id="statusChart" style="max-height:200px; max-width:200px;"></canvas>
                @* Selitteen lista. list-unstyled = ei bullet-pisteittä. *@
                <ul class="list-unstyled mb-0 small">
                    @* ● = unicode täytetty ympyrä (kirjoitettu tekstinä). *@
                    <li><span class="badge bg-primary me-1">●</span> Avoin: <strong>@Model.CountOpen</strong></li>
                    <li><span class="badge bg-info text-dark me-1">●</span> Käsittelyssä: <strong>@Model.CountInProgress</strong></li>
                    <li><span class="badge bg-warning text-dark me-1">●</span> Odottaa asiakasta: <strong>@Model.CountWaitingCustomer</strong></li>
                    <li><span class="badge bg-success me-1">●</span> Ratkaistu: <strong>@Model.CountResolved</strong></li>
                    <li><span class="badge bg-secondary me-1">●</span> Suljettu: <strong>@Model.CountClosed</strong></li>
                </ul>
            </div>
        </div>
    </div>

    @* ── Palautekeskiarvo ── *@
    <div class="col-md-2 d-flex">
        <div class="card h-100 w-100 text-center">
            <div class="card-header"><i class="bi bi-star me-2 text-warning"></i>Palautteet</div>
            @* py-4 = tilava yläpadding. flex-column + justify-content-center = pystysuunnassa keskitetty. *@
            <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
                @* Näytetään vain jos arviota on. AvgFeedbackRating on nullable decimal?. *@
                @if (Model.AvgFeedbackRating.HasValue)
                {
                    @* Suuri numeroarvo (esim. "4,3"). "F1" = yksi desimaali. *@
                    <div class="display-5 fw-bold text-warning mb-1">
                        @Model.AvgFeedbackRating.Value.ToString("F1")
                    </div>
                    @* Tähtikuvake 1–5:lle. *@
                    <div class="d-flex gap-1 mb-2">
                        @for (int s = 1; s <= 5; s++)
                        {
                            @* fill = kuinka paljon tähteä täytetään.
                               Esim. s=4, AvgRating=3.7 → fill = 3.7-3 = 0.7 → puolikas tähti. *@
                            double fill = Model.AvgFeedbackRating.Value - (s - 1);
                            @* Valitaan ikoni: täytetty (>=1), puolikas (>=0.5), tyhjä (<0.5). *@
                            string icon = fill >= 1 ? "bi-star-fill" : fill >= 0.5 ? "bi-star-half" : "bi-star";
                            <i class="bi @icon text-warning"></i>
                        }
                    </div>
                    @* Arvioiden lukumäärä. *@
                    <div class="small text-muted">@Model.FeedbackCount arviota</div>
                }
                else
                {
                    <div class="text-muted small">Ei palautteita</div>
                }
            </div>
        </div>
    </div>

    @* ── Laskutustiivistelmä ── *@
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-receipt me-2"></i>Laskutustiivistelmä (@Model.MonthsBack kk)</div>
            <div class="card-body">
                @* Kolme summaa vierekkäin. *@
                <div class="row text-center g-2">
                    <div class="col-4">
                        <div class="p-2 rounded bg-light">
                            @* "N0" = ilman desimaaleja (pyöristettynä tuhansiin). *@
                            <div class="fs-5 fw-bold text-primary">@Model.TotalBilledIncl.ToString("N0") €</div>
                            <div class="small text-muted">Laskutettu yhteensä</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-light">
                            <div class="fs-5 fw-bold text-success">@Model.TotalPaid.ToString("N0") €</div>
                            <div class="small text-muted">Maksettu</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-light">
                            @* Avoin saldo = laskutettu - maksettu. *@
                            <div class="fs-5 fw-bold text-danger">@((Model.TotalBilledIncl - Model.TotalPaid).ToString("N0")) €</div>
                            <div class="small text-muted">Avoin saldo</div>
                        </div>
                    </div>
                </div>
                @* Pieni laskutuskaavio kortin alaosassa. *@
                <canvas id="billingChart" class="mt-3" style="max-height:150px;"></canvas>
            </div>
        </div>
    </div>

</div>

@* ── Laskutustaulukko kuukausittain ── *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-table me-2"></i>Laskutus kuukausittain</span>
        <div class="d-flex gap-2">
            <a asp-action="ExportBillingCsv" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-download me-1"></i>CSV
            </a>
            <a asp-action="ExportBillingPdf" asp-route-monthsBack="@Model.MonthsBack"
               class="btn btn-outline-danger btn-sm">
                <i class="bi bi-file-pdf me-1"></i>PDF
            </a>
        </div>
    </div>
    <div class="table-responsive">
        @* table-dark otsikko = tumma taulukon otsikko (korostaa yhteenvetotaulukkoa). *@
        <table class="table table-sm table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Kuukausi</th>
                    <th class="text-end">Laskuja</th>
                    <th class="text-end">Veroton</th>
                    <th class="text-end">ALV</th>
                    <th class="text-end">Yhteensä</th>
                    <th class="text-end">Maksettu</th>
                    <th class="text-end">Avoin</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.MonthlyStats)
                {
                    @* Avoin saldo kuukaudelle. *@
                    var open = s.TotalIncl - s.PaidAmount;
                    <tr>
                        @* Kuukausinimi (esim. "Toukokuu 2025"). *@
                        <td>@s.Label</td>
                        <td class="text-end">@s.InvoiceCount</td>
                        @* "N2" = kaksi desimaalia. *@
                        <td class="text-end text-muted">@s.TotalExcl.ToString("N2") €</td>
                        <td class="text-end text-muted">@s.TotalVat.ToString("N2") €</td>
                        <td class="text-end fw-semibold">@s.TotalIncl.ToString("N2") €</td>
                        @* Maksettu: näytetään vain jos > 0, muuten "—". *@
                        <td class="text-end text-success">@(s.PaidAmount > 0 ? s.PaidAmount.ToString("N2") + " €" : "—")</td>
                        @* Avoin saldo punaisella jos > 0. *@
                        <td class="text-end @(open > 0 ? "text-danger" : "text-muted")">
                            @(open > 0 ? open.ToString("N2") + " €" : "—")
                        </td>
                    </tr>
                }
            </tbody>
            @* tfoot = yhteensä-rivi. table-light + fw-bold = korostettu. *@
            <tfoot class="table-light fw-bold">
                <tr>
                    <td>Yhteensä</td>
                    @* Sum() = LINQ-aggregointi kaikkien kuukausien arvoista. *@
                    <td class="text-end">@Model.MonthlyStats.Sum(s => s.InvoiceCount)</td>
                    <td class="text-end">@Model.TotalBilledExcl.ToString("N2") €</td>
                    @* ALV yhteensä = kokonaissumma - veroton. *@
                    <td class="text-end">@((Model.TotalBilledIncl - Model.TotalBilledExcl).ToString("N2")) €</td>
                    <td class="text-end text-primary">@Model.TotalBilledIncl.ToString("N2") €</td>
                    <td class="text-end text-success">@Model.TotalPaid.ToString("N2") €</td>
                    <td class="text-end text-danger">@((Model.TotalBilledIncl - Model.TotalPaid).ToString("N2")) €</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@* Scripts: Chart.js + kaavioiden alustuskoodi. *@
@section Scripts {
@* Chart.js ladataan CDN:stä. 4.4.4 = tietty versio (ei "latest").
   UMD = Universal Module Definition: toimii sekä CommonJS- että script-tag-ympäristössä. *@
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
@* IIFE: sulkee kaaviomuuttujat paikalliseen scopeen. *@
(function () {
    @* Razor kirjoittaa JSON-taulukot suoraan JS-muuttujiin.
       Html.Raw() estää HTML-enkoodauksen (< > & jne.). *@
    const labels   = @Html.Raw(chartLabels);
    const created  = @Html.Raw(chartCreated);
    const resolved = @Html.Raw(chartResolved);

    @* Tikettien viikoittainen kehitys — palkkikaavio.
       new Chart(elementti, { type, data, options }) = Chart.js-kaavio. *@
    new Chart(document.getElementById('ticketChart'), {
        type: 'bar',
        data: {
            labels,
            datasets: [
                {
                    label: 'Luotu',
                    data: created,
                    @* rgba(59, 130, 246, 0.7) = sininen 70 % läpinäkyvyydellä. *@
                    backgroundColor: 'rgba(59, 130, 246, 0.7)',
                    borderRadius: 4  @* Pylväiden pyöristetyt yläkulmat. *@
                },
                {
                    label: 'Ratkaistu / Suljettu',
                    data: resolved,
                    backgroundColor: 'rgba(34, 197, 94, 0.7)',
                    borderRadius: 4
                }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'top' } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } @* Y-akseli alkaa 0:sta, kokonaisluvut. *@
        }
    });

    @* Tila-jakauma — donut-kaavio.
       type: 'doughnut' = donut (reikä keskellä). *@
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Avoin', 'Käsittelyssä', 'Odottaa', 'Ratkaistu', 'Suljettu'],
            datasets: [{
                @* Razor kirjoittaa C#-integerlukut suoraan JS-taulukkoon. *@
                data: [
                    @Model.CountOpen,
                    @Model.CountInProgress,
                    @Model.CountWaitingCustomer,
                    @Model.CountResolved,
                    @Model.CountClosed
                ],
                @* Värit vastaavat HTML-selitteen badge-värejä. *@
                backgroundColor: ['#3b82f6', '#06b6d4', '#f59e0b', '#22c55e', '#6b7280']
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } } @* Legenda piilotettu (käytetään HTML-selitettä). *@
        }
    });

    @* Laskutuskaavio kuukausittain. *@
    const bLabels  = @Html.Raw(billingLabels);
    const bTotals  = @Html.Raw(billingTotals);
    const bPaid    = @Html.Raw(billingPaid);

    new Chart(document.getElementById('billingChart'), {
        type: 'bar',
        data: {
            labels: bLabels,
            datasets: [
                {
                    label: 'Laskutettu',
                    data: bTotals,
                    backgroundColor: 'rgba(59, 130, 246, 0.5)',
                    borderRadius: 3
                },
                {
                    label: 'Maksettu',
                    data: bPaid,
                    backgroundColor: 'rgba(34, 197, 94, 0.7)',
                    borderRadius: 3
                }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'top' } },
            scales: { y: { beginAtZero: true } }
        }
    });
})();
</script>
}
