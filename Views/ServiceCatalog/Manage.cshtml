@model IEnumerable<HakaTech.Portal.Models.Domain.ServiceCatalogItem>
@{
    ViewData["Title"] = "Palvelukatalogi – Hallinta";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-gear me-2"></i>Palvelukatalogi – Hallinta</h2>
    <div class="d-flex gap-2">
        <a asp-action="Requests" class="btn btn-outline-secondary">
            <i class="bi bi-envelope-open me-1"></i>Tarjouspyynnöt
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Lisää palvelu
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string sMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>@sMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i>Ei palveluja. Lisää ensimmäinen palvelu yllä.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nimi</th>
                    <th>Kategoria</th>
                    <th>Kuvaus</th>
                    <th class="text-end">Lähtöhinta</th>
                    <th class="text-center">Tila</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr class="@(!s.IsActive ? "table-secondary text-muted" : "")">
                        <td class="fw-semibold">@s.Name</td>
                        <td class="small">@(s.Category ?? "—")</td>
                        <td class="small text-truncate" style="max-width:280px;">@s.Description</td>
                        <td class="text-end small">
                            @(s.Price.HasValue ? s.Price.Value.ToString("N0") + " €" : "—")
                        </td>
                        <td class="text-center">
                            @if (s.IsActive)
                            {
                                <span class="badge bg-success">Aktiivinen</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Poistettu</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@s.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @if (s.IsActive)
                            {
                                <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Poistetaanko palvelu käytöstä?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
