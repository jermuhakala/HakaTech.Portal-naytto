<!DOCTYPE html>
<html lang="fi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – HakaTech Portal</title>
    <meta name="description" content="HakaTech asiakasportaali – hallinnoi tikettejä, laskuja ja asiakkuuksia." />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">

    @* ── Sivupalkki ──────────────────────────────────────────────── *@
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <img src="~/img/logo.png" alt="HakaTech Logo" class="brand-img" style="height: 32px; width: 32px; border-radius: 6px; object-fit: cover;" />
            <span class="brand-text">HakaTech</span>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Päävalikko</span>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-speedometer2"></i><span>Dashboard</span>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ticket" ? "active" : "")"
                   asp-controller="Ticket" asp-action="Index">
                    <i class="bi bi-ticket-detailed"></i><span>Tiketit</span>
                </a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")"
                   asp-controller="Invoice" asp-action="Index">
                    <i class="bi bi-receipt"></i><span>Laskut</span>
                </a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceCatalog" ? "active" : "")"
                   asp-controller="ServiceCatalog" asp-action="Index">
                    <i class="bi bi-grid"></i><span>Palvelut</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <span class="nav-section-label mt-3">Hallinta</span>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")"
                       asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-building"></i><span>Asiakkaat</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Register" ? "active" : "")"
                       asp-controller="Account" asp-action="Register">
                        <i class="bi bi-person-plus"></i><span>Luo käyttäjä</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")"
                       asp-controller="Report" asp-action="Index">
                        <i class="bi bi-bar-chart-line"></i><span>Raportit</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" ? "active" : "")"
                       asp-controller="Announcement" asp-action="Index">
                        <i class="bi bi-megaphone"></i><span>Tiedotteet</span>
                    </a>
                }
            }
        </nav>

        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="user-info">
                    <div class="user-avatar">
                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "?")
                    </div>
                    <div class="user-details">
                        <span class="user-name">@User.Identity.Name</span>
                        <span class="user-role">@(User.IsInRole("Admin") ? "Administrator" : "Asiakas")</span>
                    </div>
                </div>
                <div class="sidebar-actions">
                    <a asp-controller="Account" asp-action="ChangePassword" class="sidebar-action-link" title="Vaihda salasana">
                        <i class="bi bi-key"></i>
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="sidebar-action-link" title="Kirjaudu ulos">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn-sidebar-login">
                    <i class="bi bi-box-arrow-in-right"></i> Kirjaudu sisään
                </a>
            }
        </div>
    </aside>

    @* ── Mobiilinav + pääsisältö ───────────────────────────────── *@
    <div class="main-wrapper">
        <header class="topbar d-sm-none">
            <button class="topbar-toggle" id="sidebarToggle" onclick="document.getElementById('sidebar').classList.toggle('open')">
                <i class="bi bi-list"></i>
            </button>
            <span class="topbar-title">HakaTech Portal</span>
        </header>

        <main class="main-content" role="main">
            @RenderBody()
        </main>

        <footer class="main-footer">
            <span>&copy; 2026 HakaTech &mdash; <a asp-action="Privacy" asp-controller="Home">Tietosuoja</a></span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
