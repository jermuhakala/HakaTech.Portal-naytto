@*
    _ToastHost.cshtml — Toast-ilmoituksien isäntä. Lukee TempDatasta
    palautteet (esim. "SuccessMessage") ja syöttää ne JavaScriptille,
    joka näyttää ne pieninä popup-ilmoituksina sivun reunassa.
*@
@using System.Text.Json
@{
    var seed = new List<object>();
    // Tuetaan sekä uutta lyhyttä avainmuotoa (Success/Error/...) että
    // vanhempaa controllerien käytäntöä (SuccessMessage/ErrorMessage/...).
    var keyMap = new (string key, string tone)[]
    {
        ("Success",        "success"),
        ("SuccessMessage", "success"),
        ("Error",          "danger"),
        ("ErrorMessage",   "danger"),
        ("Warning",        "warning"),
        ("WarningMessage", "warning"),
        ("Info",           "info"),
        ("InfoMessage",    "info")
    };
    foreach (var (key, tone) in keyMap)
    {
        if (TempData[key] is string msg && !string.IsNullOrWhiteSpace(msg))
        {
            seed.Add(new { tone, msg });
            TempData.Remove(key);
        }
    }
    var json = JsonSerializer.Serialize(seed);
}
<div id="toastHost" aria-live="polite" aria-atomic="true"></div>
<script>
    window.__toasts = @Html.Raw(json);
</script>
