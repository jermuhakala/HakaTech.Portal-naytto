@*
    ════════════════════════════════════════════════════════════════════
    Ticket/Create.cshtml — Uuden tiketin luontilomake.

    Rakenne:
      - Otsikkorivi (page-header): otsikko + "Takaisin"- ja "Lähetä"-painikkeet
      - form-grid -asettelu: pääsisältö (otsikko + kuvaus) vasemmalle,
        metatiedot (asiakas/kategoria/prioriteetti) oikealle sivupalkkiin
      - Live-haku tietopankista (kb-suggestions): kun käyttäjä kirjoittaa otsikkoa,
        haetaan automaattisesti sopivia artikkeleita → itsepalveluratkaisu
        ennen tiketin lähettämistä (debounce 350ms, min 3 merkkiä)
      - Adminille asiakaspudotusvalikko; asiakkaalle piilokenttä (tietoturva)

    JavaScript-toiminnot:
      - IIFE-rakenne (heti suoritettava funktio) suojaa muuttujat
      - fetch('/KnowledgeBase/Search?q=...') → hakee artikkeleita JSON-muodossa
      - debounce = setTimeout jolla odotetaan kirjoituspause ennen hakua
      - encodeURIComponent suojaa erikoismerkit URL:ssa
      - blur-tapahtuma piilottaa ehdotukset kun kenttä menettää fokuksen
        (300ms viive: ehdotuksen klikkaus ehtii toimia ennen piilotusta)

    Yhteys: TicketController.Create (GET + POST).
    ════════════════════════════════════════════════════════════════════
*@

@* Malli = TicketCreateViewModel. Sisältää lomakkeen kentät:
   Title, Description, Category, Priority, CustomerId, CustomerOptions. *@
@model HakaTech.Portal.Models.ViewModels.TicketCreateViewModel

@* Tuodaan enumit käyttöön: TicketCategory ja TicketPriority. *@
@using HakaTech.Portal.Models.Domain

@{
    @* Selaimen välilehden otsikko. *@
    ViewData["Title"] = L["Ticket.Create.Title"].Value;

    @* Leivänmurupolku yläpalkkiin: "Tiketit" → "Uusi tiketti".
       Null Href = ollaan tällä sivulla (ei linkkiä, vain teksti). *@
    ViewData["Breadcrumbs"] = new List<(string, string?)>
    {
        (L["Ticket.Index.Title"].Value, Url.Action("Index", "Ticket")),
        (L["Ticket.Create.Title"].Value, null)
    };

    @* Tarkistetaan käyttäjän rooli: admin saa asiakaspudotusvalikon,
       asiakas ei — tietoturvasyistä asiakas ei saa valita yritystä itse. *@
    bool isAdmin = User.IsInRole("Admin");

    @* Apufunktiot lokalisoituihin näyttönimiin.
       $"TicketCategory.{c}" = interpoloitu avain, esim. "TicketCategory.Software"
       → Resources-tiedostosta haetaan käännös (esim. "Ohjelmistot").
       Näin enumin arvot käännetään automaattisesti tarvitsematta if-ketjua. *@
    string CategoryLabel(TicketCategory c) => L[$"TicketCategory.{c}"].Value;
    string PriorityLabel(TicketPriority p) => L[$"TicketPriority.{p}"].Value;
}

@* ── Sivun otsikkopalkki ─────────────────────────────────────────── *@
@* page-header = mukautettu CSS-luokka (_Layout.cshtml tai site.css).
   Sisältää vasemmalla otsikon (page-header-main) ja oikealla toiminnot (page-header-actions). *@
<header class="page-header">
    <div class="page-header-main">
        @* Pääotsikko ikonilla. L["Ticket.Create.Heading"] = lokalisoitu teksti. *@
        <h1 class="page-header-title"><i class="bi bi-ticket-perforated"></i> @L["Ticket.Create.Heading"]</h1>
        @* Alaotsikko / kuvaus. *@
        <p class="page-header-sub">@L["Ticket.Create.Title"]</p>
    </div>
    <div class="page-header-actions">
        @* Takaisin tikettilistaan. btn-lnr = custom-painike, variant-ghost = läpinäkyvä tyyli. *@
        <a asp-action="Index" class="btn-lnr variant-ghost size-sm">
            <i class="bi bi-arrow-left"></i> @L["UI.Button.Back"]
        </a>
        @* Lähetä-painike on otsikkopalkissa (ei lomakkeen sisällä).
           form="ticketCreateForm" = HTML5-attribuutti joka kytkee tämän painikkeen
           id="ticketCreateForm" -lomakkeeseen. Näin painike voi olla fyysisesti
           eri paikassa sivulla kuin itse form-elementti. *@
        <button type="submit" form="ticketCreateForm" class="btn-lnr variant-primary size-sm">
            <i class="bi bi-send"></i> @L["Ticket.Create.Submit"]
        </button>
    </div>
</header>

@* ── Varsinainen lomake ──────────────────────────────────────────────
   id="ticketCreateForm" = otsikkopalkin Lähetä-painike viittaa tähän form-elementtiin.
   asp-action="Create" + method="post" → POST /Ticket/Create.
   @Html.AntiForgeryToken lisätään implisiittisesti asp-action-lomakkeisiin. *@
<form asp-action="Create" method="post" id="ticketCreateForm">

    @* Palvelinpuolen validoinnin yhteenvetolaatikko.
       "ModelOnly" = vain mallin tason virheet (ei yksittäisten kenttien).
       Näkyy vain jos kontrolleri palauttaa ModelState-virheitä.
       Väri, padding ja color haetaan CSS-muuttujista (var(--danger-fg)). *@
    <div asp-validation-summary="ModelOnly" class="card-lnr tone-danger" style="padding: 12px 16px; margin-bottom: 16px; color: var(--danger-fg);"></div>

    @* form-grid = mukautettu CSS-layout (kaksipalstainen).
       form-grid-main = pääsisältö (leveämpi, vasemmalla).
       form-grid-aside = sivupalkki (kapeampi, oikealla). *@
    <div class="form-grid">

        @* ── Pääsisältö-sarake ─────────────────────────────────── *@
        <div class="form-grid-main">
            @* fieldset + legend = semanttinen ryhmittely lomakekentille.
               Parantaa saavutettavuutta (ruudunlukijat lukevat legendin). *@
            <fieldset class="form-section">
                <legend>@L["UI.Form.Section.Main"]</legend>

                @* ── Otsikko-kenttä ── *@
                <div class="form-field">
                    @* asp-for="Title" kytkee labelin TicketCreateViewModel.Title-kenttään.
                       Näyttää automaattisesti [Display(Name="...")]-attribuutin arvon. *@
                    <label asp-for="Title" class="form-field-label"></label>
                    <div class="form-field-input-wrap">
                        @* id="create-title" = JavaScript viittaa tähän.
                           autocomplete="off" = estää selaimen ehdotukset (tiketin otsikko on uniikki). *@
                        <input asp-for="Title" class="form-control" id="create-title"
                               placeholder="@L["Ticket.Create.TitlePlaceholder"]" autocomplete="off" />
                    </div>
                    @* Kentäkohtainen validointivirheilmoitus. *@
                    <span asp-validation-for="Title" class="form-field-error"></span>

                    @* ── Tietopankin ehdotusalue ──
                       Piilotettu oletuksena (display:none). JavaScript näyttää sen
                       kun haku löytää osumia. Sisältö rakennetaan JS:ssä dynaamisesti. *@
                    <div id="kb-suggestions" class="mt-2" style="display:none">
                        @* card-lnr = mukautettu korttikomponentti. *@
                        <div class="card-lnr" style="padding: 10px 14px;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                @* Keltainen hehkulamppu-ikoni: "ehdotuksia löydetty". *@
                                <i class="bi bi-lightbulb-fill" style="color: var(--warning-fg);"></i>
                                <span class="fw-semibold small">@L["Ticket.Create.KbSuggestions"]</span>
                            </div>
                            @* list-unstyled = poistetaan oletuspisteet listasta.
                               Tähän <ul>:ään JavaScript lisää <li>-ehdotukset. *@
                            <ul id="kb-suggestion-list" class="list-unstyled mb-0"></ul>
                        </div>
                    </div>
                </div>

                @* ── Kuvaus-kenttä ── *@
                <div class="form-field">
                    <label asp-for="Description" class="form-field-label"></label>
                    @* rows="8" = kahdeksan riviä näkyvissä — kuvaus voi olla pitkä. *@
                    <textarea asp-for="Description" class="form-control" id="create-description"
                              rows="8"
                              placeholder="@L["Ticket.Create.DescriptionPlaceholder"]"></textarea>
                    <span asp-validation-for="Description" class="form-field-error"></span>
                </div>
            </fieldset>
        </div>

        @* ── Sivupalkki: metatiedot ────────────────────────────── *@
        <aside class="form-grid-aside">
            <fieldset class="form-section">
                <legend>@L["UI.Form.Section.Meta"]</legend>

                @* ── Asiakaspudotusvalikko (vain admin) ── *@
                @* Tietoturvaperiaate: asiakas ei saa valita yritystä itse
                   — muuten voisi luoda tiketin toisen yrityksen nimissä (IDOR-haavoittuvuus).
                   Kontrolleri asettaa CustomerId:n palvelinpuolella käyttäjän omista tiedoista. *@
                @if (isAdmin)
                {
                    <div class="form-field">
                        <label asp-for="CustomerId" class="form-field-label"></label>
                        @* asp-items="Model.CustomerOptions" = täytetty kontrollerissa.
                           Generoi <option>-elementit SelectListItem-listasta. *@
                        <select asp-for="CustomerId" asp-items="Model.CustomerOptions"
                                id="create-customer" class="form-select">
                            <option value="">@L["Ticket.Create.SelectCustomer"]</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="form-field-error"></span>
                    </div>
                }
                else
                {
                    @* Asiakaskäyttäjälle: lähetetään tyhjä piilokenttä lomakkeen mukana.
                       Kontrolleri IGNOROI tämän arvon ja asettaa CustomerId:n käyttäjän
                       omasta profiilista — tietoturva. *@
                    <input type="hidden" asp-for="CustomerId" />
                }

                @* ── Kategoriapudotusvalikko ──
                   Enum.GetValues<TicketCategory>() = palauttaa kaikki enumin arvot:
                   Network, Hardware, Software, Email, Access, Other.
                   Jokaisesta generoidaan oma <option> CategoryLabel-funktioita käyttäen. *@
                <div class="form-field">
                    <label asp-for="Category" class="form-field-label"></label>
                    <select asp-for="Category" id="create-category" class="form-select">
                        @foreach (var c in Enum.GetValues<TicketCategory>())
                        {
                            @* value="@c" = enumin arvo merkkijonona (esim. "Software").
                               @CategoryLabel(c) = suomenkielinen näyttönimi. *@
                            <option value="@c">@CategoryLabel(c)</option>
                        }
                    </select>
                </div>

                @* ── Prioriteettipudotusvalikko ──
                   Arvot: Low, Normal, High, Critical — PriorityLabel kääntää ne suomeksi. *@
                <div class="form-field">
                    <label asp-for="Priority" class="form-field-label"></label>
                    <select asp-for="Priority" id="create-priority" class="form-select">
                        @foreach (var p in Enum.GetValues<TicketPriority>())
                        {
                            <option value="@p">@PriorityLabel(p)</option>
                        }
                    </select>
                </div>
            </fieldset>
        </aside>
    </div>
</form>

@* ──────────────────────────────────────────────────────────────────
   Scripts-osio: lisätään sivun loppuun (_Layout.cshtml renderöi sen).
   ────────────────────────────────────────────────────────────────── *@
@section Scripts {
    @* jQuery Validation + Unobtrusive — käsittelee asp-validation-* -ohjeistukset
       client-puolella. Virheet näkyvät heti ilman sivun latausta. *@
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        // IIFE (Immediately Invoked Function Expression) = heti suoritettava funktio.
        // Sulkee kaikki muuttujat omaan scopeensa → ei saastuta globaalia window-objektia.
        (function () {
            // Haetaan DOM-elementit kerran muistiin suorituskyvyn vuoksi.
            const titleInput  = document.getElementById('create-title');         // otsikkokenttä
            const panel       = document.getElementById('kb-suggestions');        // ehdotuspaneeli
            const list        = document.getElementById('kb-suggestion-list');    // <ul> ehdotuksille
            let   debounce;                                                       // setTimeout-viite

            // Turvacheck: jos elementtejä ei löydy (esim. admin-näkymässä eri rakenne), lopetetaan.
            if (!titleInput) return;

            // Kuunnellaan otsikkokentän jokainen syöttötapahtuma (jokainen näppäin).
            titleInput.addEventListener('input', function () {
                // clearTimeout peruuttaa edellisen ajastimen — odotetaan kirjoitustaukoa.
                clearTimeout(debounce);

                const q = this.value.trim(); // poistetaan etu- ja jälkivälilyönnit

                // Alle 3 merkin haut ovat liian epätarkkoja → piilotetaan ehdotukset.
                if (q.length < 3) { panel.style.display = 'none'; return; }

                // "Debounce"-viive: odotetaan 350ms ennen kuin lähetetään hakupyyntö.
                // Tämä estää sen, että jokainen kirjain laukaisee oman verkkopyynnön.
                // Vain viimeisin haku suoritetaan (clearTimeout peruutti aiemmat).
                debounce = setTimeout(async function () {
                    try {
                        // fetch = selainpohjainen AJAX-pyyntö. async/await = odotellaan vastausta.
                        // encodeURIComponent suojaa erikoismerkit URL:ssa (esim. & → %26).
                        const res  = await fetch(`/KnowledgeBase/Search?q=${encodeURIComponent(q)}`);
                        // .json() = muuntaa JSON-vastauksen JavaScript-olioksi.
                        const data = await res.json();

                        // Jos hakutulos tyhjä, piilotetaan paneeli.
                        if (!data || data.length === 0) { panel.style.display = 'none'; return; }

                        // Rakennetaan HTML-merkkijono jokaisesta artikkeli-ehdotuksesta.
                        // .map() = muuntaa jokaisen a-olion HTML-merkkijonoksi.
                        // .join('') = yhdistää kaikki merkkijonot yhdeksi.
                        // target="_blank" → avataan uudessa välilehdessä, jolloin
                        // käyttäjän kirjoittamat tiketin tiedot eivät katoa.
                        list.innerHTML = data.map(a => `
                            <li class="mb-1">
                                <a href="/KnowledgeBase/Article/${a.id}" target="_blank"
                                   class="d-flex align-items-start gap-2 text-decoration-none text-body">
                                    <i class="bi bi-file-earmark-text mt-1 flex-shrink-0" style="color: var(--accent-600);"></i>
                                    <div>
                                        <span class="fw-medium small">${a.title}</span>
                                        <span class="badge-status-lnr tone-neutral ms-1" style="font-size:.7rem">${a.category}</span>
                                        <div class="text-muted" style="font-size:.78rem">${a.excerpt}</div>
                                    </div>
                                </a>
                            </li>`).join('');

                        // Näytetään ehdotuspaneeli kun tulokset on lisätty listaan.
                        panel.style.display = 'block';
                    } catch {
                        // Verkkovirhe tai virheellinen JSON-vastaus.
                        // Piilotetaan hiljaisesti — käyttäjälle ei näytetä hakuvirhettä,
                        // lomakkeen lähettäminen toimii edelleen normaalisti.
                        panel.style.display = 'none';
                    }
                }, 350); // 350ms debounce-viive
            });

            // blur = kenttä menettää fokuksen (käyttäjä klikkaa jonnekin muualle).
            // Piilotamme ehdotukset, mutta VASTA 300ms:n viiveen jälkeen.
            // Syy: jos käyttäjä klikkailee ehdotusta, click-tapahtuma laukeaa
            // ennen blur-tapahtumaa → ehdotuksen linkki ehtii toimia ennen piilotusta.
            titleInput.addEventListener('blur', function () {
                setTimeout(() => { panel.style.display = 'none'; }, 300);
            });
        })(); // IIFE: funktion määrittely ja kutsuminen yhdessä
    </script>
}
