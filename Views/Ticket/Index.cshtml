@*
    Ticket/Index.cshtml — Tikettilista. Suodatettavissa tilan, prioriteetin
    ja asiakkaan mukaan + vapaa tekstihaku. Asiakas näkee vain oman
    yrityksensä tiketit, admin näkee kaikki.
*@
@model IEnumerable<HakaTech.Portal.Models.Domain.Ticket>
@using HakaTech.Portal.Models.Domain
@{
    ViewData["Title"] = L["Ticket.Index.Title"].Value;
    bool isAdmin      = (bool)(ViewBag.IsAdmin ?? false);
    var statusFilter  = ViewBag.StatusFilter  as TicketStatus?;
    var priorityFilter= ViewBag.PriorityFilter as TicketPriority?;
    string? search    = ViewBag.Search;

    string StatusLabel(TicketStatus s)   => L[$"TicketStatus.{s}"].Value;
    string PriorityLabel(TicketPriority p) => L[$"TicketPriority.{p}"].Value;
    string CategoryLabel(TicketCategory c) => L[$"TicketCategory.{c}"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-ticket-perforated me-2"></i>@L["Ticket.Index.Title"]</h2>
    <a asp-action="Create" id="btn-ticket-create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>@L["Ticket.Index.New"]
    </a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-4">
        <input type="text" name="search" value="@search"
               class="form-control" id="ticket-search"
               placeholder="@L["Ticket.Index.SearchPlaceholder"]" />
    </div>
    <div class="col-md-2">
        <select name="status" id="ticket-status" class="form-select">
            <option value="">@L["Ticket.Index.AllStatuses"]</option>
            @foreach (var s in Enum.GetValues<TicketStatus>())
            {
                <option value="@s" selected="@(statusFilter == s)">@StatusLabel(s)</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="priority" id="ticket-priority" class="form-select">
            <option value="">@L["Ticket.Index.AllPriorities"]</option>
            @foreach (var p in Enum.GetValues<TicketPriority>())
            {
                <option value="@p" selected="@(priorityFilter == p)">@PriorityLabel(p)</option>
            }
        </select>
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-outline-secondary">
            <i class="bi bi-funnel"></i> @L["Common.Filter"]
        </button>
        <a asp-action="Index" class="btn btn-outline-danger ms-1" title="@L["Common.ClearFilter"]">
            <i class="bi bi-x-lg"></i>
        </a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-ticket-perforated text-muted" style="font-size:3rem"></i>
            <p class="mt-3 mb-1 fw-semibold text-muted">@L["Ticket.Index.Empty.Title"]</p>
            <p class="text-muted small mb-3">@L["Ticket.Index.Empty.Sub"]</p>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>@L["Ticket.Index.Empty.Create"]
            </a>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th>@L["Dash.Col.Title"]</th>
                    @if (isAdmin) { <th>@L["Dash.Col.Customer"]</th> }
                    <th>@L["Ticket.Col.Category"]</th>
                    <th>@L["Dash.Col.Priority"]</th>
                    <th>@L["Dash.Col.Status"]</th>
                    <th>@L["Dash.Col.Created"]</th>
                    <th>@L["Ticket.Col.AssignedTo"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td class="text-muted small">#@t.Id</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@t.Id"
                               class="fw-semibold text-decoration-none">@t.Title</a>
                        </td>
                        @if (isAdmin)
                        {
                            <td class="small text-muted">@(t.Customer?.CompanyName ?? "—")</td>
                        }
                        <td class="small text-muted">@CategoryLabel(t.Category)</td>
                        <td>
                            @{
                                var pBadge = t.Priority switch {
                                    TicketPriority.Critical => "bg-danger",
                                    TicketPriority.High     => "bg-warning text-dark",
                                    TicketPriority.Normal   => "bg-primary",
                                    _                       => "bg-secondary"
                                };
                            }
                            <span class="badge @pBadge">@PriorityLabel(t.Priority)</span>
                        </td>
                        <td>
                            @{
                                var sBadge = t.Status switch {
                                    TicketStatus.Open            => "bg-primary",
                                    TicketStatus.InProgress      => "bg-info text-dark",
                                    TicketStatus.WaitingCustomer => "bg-warning text-dark",
                                    TicketStatus.Resolved        => "bg-success",
                                    TicketStatus.Closed          => "bg-secondary",
                                    _                            => "bg-light text-dark"
                                };
                            }
                            <span class="badge @sBadge">@StatusLabel(t.Status)</span>
                        </td>
                        <td class="small text-muted">@t.CreatedAt.ToString("dd.MM.yy")</td>
                        <td class="small text-muted">@(t.AssignedToUser?.FullName ?? "—")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@t.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small">@string.Format(L["Ticket.Total"].Value, Model.Count())</p>
}
